---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RichText from "../components/RichText.tsx";
import { FONTS } from "../layouts/Layout.astro";
import { optimizePath } from "../lib/image";
import { reader } from "../lib/keystatic-reader";
import { slugifySection } from "../lib/slugify";

const bandeauData = (await reader.singletons.village_bandeau.read({ resolveLinkedFiles: true })) ?? ({} as any);
const sectionsData = (await reader.singletons.village_sections.read({ resolveLinkedFiles: true })) ?? ({ sections: [] } as any);
const contactData = (await reader.singletons.village_contact.read({ resolveLinkedFiles: true })) ?? ({} as any);
const parametres = (await reader.singletons.parametres.read({ resolveLinkedFiles: true })) ?? ({} as any);

const styleMap: Record<string, string> = {
  normal: 'normal',
  bold: 'bold',
  italic: 'italic',
};

const SIZE_MAP: Record<string, string> = {
  inherit: '',
  xs: '0.75rem',
  sm: '0.875rem',
  base: '1rem',
  md: '1.125rem',
  lg: '1.25rem',
  xl: '1.5rem',
  '2xl': '2rem',
  '3xl': '2.5rem',
  '4xl': '3rem',
  '5xl': '4rem',
  '6xl': '5rem',
};

const WIDTH_MAP: Record<string, string> = {
  inherit: '',
  narrow: '32ch',
  medium: '46ch',
  wide: '64ch',
  xwide: '80ch',
  xxl: '100ch',
  xxxl: '120ch',
  max: '140ch',
  full: 'none',
};

const LINE_HEIGHT_MAP: Record<string, string> = {
  inherit: '',
  tight: '1.1',
  snug: '1.3',
  normal: '1.5',
  relaxed: '1.8',
  loose: '2.1',
  xloose: '2.4',
};

function elementStyle(data: any, prefix: string, defaultColor: string, defaultWeight = '400') {
  const fontKey = data[`${prefix}_font`];
  const fontRes = fontKey && fontKey !== 'inherit' && FONTS[fontKey] ? FONTS[fontKey] : null;
  const styleVal = data[`${prefix}_style`] || 'normal';
  const weightVal = data[`${prefix}_weight`];
  const size = SIZE_MAP[data[`${prefix}_size`]] || '';
  const color = data[`${prefix}_color`] || defaultColor;
  const align = data[`${prefix}_align`];
  const width = WIDTH_MAP[data[`${prefix}_width`]] || '';
  const lineHeight = LINE_HEIGHT_MAP[data[`${prefix}_line_height`]] || '';
  const obj: Record<string, string> = {
    color,
    fontWeight: weightVal && weightVal !== 'inherit' ? weightVal : (styleVal === 'bold' ? '700' : defaultWeight),
    fontStyle: styleVal === 'italic' ? 'italic' : 'normal',
  };
  if (fontRes) obj.fontFamily = fontRes.family;
  if (size) obj.fontSize = size;
  if (align && align !== 'inherit') obj.textAlign = align;
  if (width) obj.maxWidth = width;
  if (lineHeight) obj.lineHeight = lineHeight;
  return { obj, fontUrl: fontRes ? fontRes.url : null };
}

// Bandeau styles
const bandeauFontKey = bandeauData.font && bandeauData.font !== 'inherit' && FONTS[bandeauData.font] ? bandeauData.font : null;
const bandeauFont = bandeauFontKey ? FONTS[bandeauFontKey].family : null;
const bandeauFontUrl = bandeauFontKey ? FONTS[bandeauFontKey].url : null;
const bandeauColor = bandeauData.text_color || '#ffffff';
const bandeauIntroStyle = styleMap[bandeauData.intro_style] || 'normal';
const bandeauLabelStyleObj = elementStyle(bandeauData, 'label', bandeauColor, '700');
const bandeauTitreStyleObj = elementStyle(bandeauData, 'titre', bandeauColor, '300');

const bandeauVillage = bandeauData.bandeau_image
  ? optimizePath(bandeauData.bandeau_image.startsWith('/images/') ? bandeauData.bandeau_image : `/images/${bandeauData.bandeau_image}`)
  : optimizePath("/images/droneImageBandeau.jpg");
const bandeauLabel   = bandeauData.bandeau_label || "Le Village";
const bandeauTitre   = bandeauData.bandeau_titre || "Village Atipics";
const intro          = bandeauData.intro;
const hasIntro       = intro && Array.isArray(intro) && intro.some((node: any) => node?.children?.some((child: any) => (child.text || '').trim() !== ''));
const formLabel      = contactData.section_label || "CONTACT";
const formIntro      = contactData.form_intro    || [{ type: "paragraph", children: [{ text: "Vous souhaitez visiter le Village, collaborer avec nous ou en savoir plus sur nos espaces ? Remplissez le formulaire ci-dessous, nous reviendrons vers vous rapidement." }] }];

const contactDefaultColor = contactData.text_color || '#1A1A18';
const contactLabelStyle = elementStyle(contactData, 'label', contactDefaultColor, '700');
const contactIntroStyle = elementStyle(contactData, 'intro', contactDefaultColor);
const contactFontUrls = [contactLabelStyle.fontUrl, contactIntroStyle.fontUrl].filter(Boolean) as string[];

const fallbackImgs = ["/images/projet1.jpg", "/images/projet2.webp", "/images/projet3.jpg"];

const espaces = (sectionsData.sections || []).map((s: any, i: number) => {
  const fontKey = s.font && s.font !== 'inherit' && FONTS[s.font] ? s.font : null;
  const defaultColor = s.text_color || '#1A1A18';
  return {
    slug: slugifySection(s.title, i),
    label: s.label || '',
    title: s.title || '',
    content: s.content || [],
    images: (s.images || []).map((src: string) => optimizePath(src.startsWith('/images/') ? src : `/images/${src}`)),
    fallbackImg: fallbackImgs[i % fallbackImgs.length],
    reverse: i % 2 === 1,
    font: fontKey ? FONTS[fontKey].family : null,
    fontUrl: fontKey ? FONTS[fontKey].url : null,
    labelStyleObj: elementStyle(s, 'label', defaultColor, '700'),
    titleStyleObj: elementStyle(s, 'title', defaultColor, '300'),
    contentStyleObj: elementStyle(s, 'content', defaultColor),
  };
});
---

<Layout title={`Village Atipics — ${parametres.nom_site}`} description="L'Entrepôt, le Studio Design et l'Atelier du Village Atipics">
  <Header />
  <main style="padding-top: var(--nav-h);">

    <!-- Bandeau drone -->
    <section class="bandeau" style={`${bandeauFont ? `font-family: ${bandeauFont};` : ''}--bandeau-color:${bandeauColor};`}>
      {bandeauFontUrl && <link rel="stylesheet" href={bandeauFontUrl} />}
      {bandeauLabelStyleObj.fontUrl && <link rel="stylesheet" href={bandeauLabelStyleObj.fontUrl} />}
      {bandeauTitreStyleObj.fontUrl && <link rel="stylesheet" href={bandeauTitreStyleObj.fontUrl} />}
      <img src={bandeauVillage} alt="Vue aérienne du Village Atipics" class="bandeau__img" />
      <div class="bandeau__overlay">
        <div class="container bandeau__text">
          <p class="bandeau__label" style={bandeauLabelStyleObj.obj}>{bandeauLabel}</p>
          <h1 class="bandeau__title" style={bandeauTitreStyleObj.obj}>{bandeauTitre}</h1>
        </div>
      </div>
    </section>

    {hasIntro && (
      <section class="intro-section" style={`--intro-weight:${bandeauIntroStyle === 'bold' ? '600' : '300'};--intro-style:${bandeauIntroStyle === 'italic' ? 'italic' : 'normal'}`}>
        <div class="container">
          <RichText document={intro} className="intro-desc" />
        </div>
      </section>
    )}

    <!-- Espaces — alternance photo/texte -->
    {espaces.map((e) => (
      <section class="espace" id={e.slug} style={e.font ? `font-family: ${e.font};` : ''}>
          {e.fontUrl && <link rel="stylesheet" href={e.fontUrl} />}
          {e.labelStyleObj.fontUrl && <link rel="stylesheet" href={e.labelStyleObj.fontUrl} />}
          {e.titleStyleObj.fontUrl && <link rel="stylesheet" href={e.titleStyleObj.fontUrl} />}
          {e.contentStyleObj.fontUrl && <link rel="stylesheet" href={e.contentStyleObj.fontUrl} />}
        <div class="container">
          <div class="espace__label-row">
            <span class="espace__section-label" style={e.labelStyleObj.obj}>{e.label}</span>
            <div class="espace__rule"></div>
          </div>
          <div class:list={["espace__grid", { "espace__grid--reverse": e.reverse }]}>
            <div class="espace__img-col">
              {(e.images.length > 0 ? e.images : null) ? (
                <div class="vcarousel" data-vcarousel>
                  <div class="vcarousel__track" data-vtrack>
                    {e.images.map((src: string, j: number) => (
                      <div class:list={["vcarousel__slide", { "is-active": j === 0 }]} aria-hidden={j !== 0}>
                        <img src={src} alt={`${e.title} ${j + 1}`} class="espace__img" loading="lazy" />
                      </div>
                    ))}
                  </div>
                  {e.images.length > 1 && (
                    <>
                      <button class="vcarousel__btn vcarousel__btn--prev" aria-label="Précédent">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </button>
                      <button class="vcarousel__btn vcarousel__btn--next" aria-label="Suivant">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </button>
                      <div class="vcarousel__counter" data-vcounter></div>
                    </>
                  )}
                </div>
              ) : (
                <img src={optimizePath(e.fallbackImg)} alt={e.title} class="espace__img" loading="lazy" />
              )}
            </div>
            <div class="espace__text-col">
              <h2 class="espace__title" style={e.titleStyleObj.obj}>{e.title}</h2>
              {e.content && <RichText document={e.content} className="espace__p" style={e.contentStyleObj.obj} />}
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Formulaire de contact -->
    <section class="form-section" id="contact-village">
      {contactFontUrls.map((url) => <link rel="stylesheet" href={url} />)}
      <div class="container">
        <div class="form-label-row">
          <span class="espace__section-label" style={contactLabelStyle.obj}>{formLabel}</span>
          <div class="espace__rule"></div>
        </div>
        <div class="form-layout">
          <div class="form-intro">
            <RichText document={formIntro} className="form-intro__text" style={contactIntroStyle.obj} />
            <p class="form-intro__text">Pour toute question urgente, vous pouvez nous écrire directement à <a href={`mailto:${parametres.email}`} class="form-intro__link">{parametres.email}</a>.</p>
          </div>
          <form class="vform" name="village-contact" method="POST">
            <div class="vform__row">
              <div class="vform__group">
                <label class="vform__label" for="vc-nom">NOM</label>
                <input class="vform__input" type="text" id="vc-nom" name="nom" required autocomplete="name" />
              </div>
              <div class="vform__group">
                <label class="vform__label" for="vc-societe">SOCIÉTÉ</label>
                <input class="vform__input" type="text" id="vc-societe" name="societe" autocomplete="organization" />
              </div>
            </div>
            <div class="vform__row">
              <div class="vform__group">
                <label class="vform__label" for="vc-email">EMAIL</label>
                <input class="vform__input" type="email" id="vc-email" name="email" required autocomplete="email" />
              </div>
              <div class="vform__group">
                <label class="vform__label" for="vc-tel">TÉLÉPHONE</label>
                <input class="vform__input" type="tel" id="vc-tel" name="telephone" autocomplete="tel" />
              </div>
            </div>
            <div class="vform__group">
              <label class="vform__label" for="vc-projet">PROJET</label>
              <input class="vform__input" type="text" id="vc-projet" name="projet" />
            </div>
            <div class="vform__group">
              <label class="vform__label" for="vc-message">MESSAGE</label>
              <textarea class="vform__input vform__textarea" id="vc-message" name="message" rows="5" required></textarea>
            </div>
            <label class="vform__check">
              <input class="vform__check-input" type="checkbox" name="newsletter" />
              <span class="vform__check-box" aria-hidden="true"></span>
              <span class="vform__check-label">J'accepte de recevoir la newsletter Atipics</span>
            </label>
            <button type="submit" class="vform__submit">
              ENVOYER <span class="vform__arrow" aria-hidden="true">→</span>
            </button>
          </form>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('[data-vcarousel]').forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll('.vcarousel__slide')) as HTMLElement[];
    const prev   = carousel.querySelector('.vcarousel__btn--prev') as HTMLButtonElement | null;
    const next   = carousel.querySelector('.vcarousel__btn--next') as HTMLButtonElement | null;
    const counter = carousel.querySelector('[data-vcounter]') as HTMLElement | null;
    let cur = 0;

    function go(n: number) {
      slides[cur].classList.remove('is-active');
      slides[cur].setAttribute('aria-hidden', 'true');
      cur = ((n % slides.length) + slides.length) % slides.length;
      slides[cur].classList.add('is-active');
      slides[cur].setAttribute('aria-hidden', 'false');
      if (counter) counter.textContent = `${cur + 1} / ${slides.length}`;
    }

    if (counter) counter.textContent = `1 / ${slides.length}`;
    prev?.addEventListener('click', () => go(cur - 1));
    next?.addEventListener('click', () => go(cur + 1));
  });
</script>

<style>
  /* ─── Bandeau drone ─── */
  .bandeau {
    position: relative;
    width: 100%;
    height: 58vh;
    min-height: 360px;
    overflow: hidden;
  }
  .bandeau__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }
  .bandeau__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.52) 0%, rgba(0,0,0,0.1) 55%, transparent 100%);
    display: flex;
    align-items: flex-end;
  }
  .bandeau__text {
    padding-bottom: var(--sp-lg);
    color: var(--bandeau-color, #fff);
  }
  .bandeau__label {
    font-size: var(--text-xs);
    font-weight: var(--bandeau-label-weight, 400);
    font-style: var(--bandeau-label-style, normal);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 0.4rem;
  }
  .bandeau__title {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: var(--bandeau-titre-weight, 200);
    font-style: var(--bandeau-titre-style, normal);
    letter-spacing: -0.03em;
    line-height: 0.92;
  }

  /* ─── Intro ─── */
  .intro-section {
    border-bottom: 1px solid var(--c-border);
    padding-block: var(--sp-md);
  }
  .intro-desc {
    font-size: var(--text-base);
    font-weight: var(--intro-weight, 300);
    font-style: var(--intro-style, normal);
    color: var(--c-muted);
    line-height: 1.75;
    max-width: 72ch;
  }

  /* ─── Label row ─── */
  .espace__label-row {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    padding-top: var(--sp-lg);
    padding-bottom: var(--sp-md);
  }
  .espace__section-label {
    font-size: var(--text-xs);
    font-weight: var(--section-label-weight, 600);
    font-style: var(--section-label-style, normal);
    letter-spacing: 0.18em;
    color: var(--section-color, var(--c-muted));
    white-space: nowrap;
    flex-shrink: 0;
  }
  .espace__rule {
    flex: 1;
    height: 1px;
    background: var(--c-border);
  }

  /* ─── Espace grid ─── */
  .espace {
    padding-bottom: var(--sp-lg);
    border-bottom: 1px solid var(--c-border);
  }
  .espace:last-of-type { border-bottom: none; }
  .espace:nth-of-type(even) { background: #FFFFFF; }

  .espace__grid {
    display: grid;
    grid-template-columns: 48% 1fr;
    gap: var(--sp-xl);
    align-items: start;
  }
  .espace__grid--reverse {
    grid-template-columns: 1fr 48%;
  }
  .espace__grid--reverse .espace__img-col { order: 2; }
  .espace__grid--reverse .espace__text-col { order: 1; }

  .espace__img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    display: block;
  }

  /* ─── Village carousel ─── */
  .vcarousel {
    position: relative;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--c-surface);
  }
  .vcarousel__track { position: absolute; inset: 0; }
  .vcarousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .vcarousel__slide.is-active { opacity: 1; pointer-events: auto; }
  .vcarousel__slide .espace__img { aspect-ratio: unset; height: 100%; }

  .vcarousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.88);
    border: none;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--c-text);
    opacity: 0;
    transition: opacity 0.2s, background 0.15s;
    z-index: 2;
  }
  .vcarousel:hover .vcarousel__btn { opacity: 1; }
  .vcarousel__btn:hover { background: #fff; }
  .vcarousel__btn--prev { left: 0.5rem; }
  .vcarousel__btn--next { right: 0.5rem; }

  .vcarousel__counter {
    position: absolute;
    bottom: 0.6rem;
    right: 0.75rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #fff;
    background: rgba(0,0,0,0.35);
    padding: 0.2rem 0.5rem;
    z-index: 2;
  }

  .espace__text-col {
    padding-top: 0.25rem;
  }

  .espace__title {
    font-size: var(--text-xl);
    font-weight: var(--section-titre-weight, 300);
    font-style: var(--section-titre-style, normal);
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-sm);
    color: var(--section-color, inherit);
  }
  .espace__p {
    font-size: var(--text-xs);
    font-weight: var(--section-text-weight, 400);
    font-style: var(--section-text-style, normal);
    color: var(--section-color, var(--c-muted));
    line-height: 1.8;
    margin-bottom: 1.5rem;
    max-width: 48ch;
    overflow-wrap: break-word;
  }
  .espace__p:last-child { margin-bottom: 0; }
  :global(.espace__p) {
    font-size: var(--text-xs);
    font-weight: var(--section-text-weight, 400);
    font-style: var(--section-text-style, normal);
    color: var(--section-color, var(--c-muted));
    line-height: 1.8;
    margin-bottom: 1.5rem;
    max-width: 48ch;
    overflow-wrap: break-word;
  }
  :global(.espace__p:last-child) { margin-bottom: 0; }
  :global(.intro-desc) {
    font-size: var(--text-base);
    font-weight: var(--intro-weight, 300);
    font-style: var(--intro-style, normal);
    color: var(--c-muted);
    line-height: 1.75;
    max-width: 72ch;
  }

  /* ─── Form section ─── */
  .form-section {
    padding-block: var(--sp-lg);
    border-top: 1px solid var(--c-border);
  }

  .form-label-row {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    margin-bottom: var(--sp-md);
  }

  .form-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-xl);
    align-items: start;
  }

  .form-intro__text {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.8;
    margin-bottom: var(--sp-sm);
    max-width: 38ch;
  }
  .form-intro__link {
    color: var(--c-text);
    border-bottom: 1px solid var(--c-border);
    transition: border-color 0.2s;
  }
  .form-intro__link:hover { border-bottom-color: var(--c-text); }

  /* ─── Form ─── */
  .vform {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }

  .vform__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-sm);
  }

  .vform__group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .vform__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--c-muted);
  }

  .vform__input {
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    padding: 0.6rem 0.75rem;
    font-size: var(--text-xs);
    font-family: var(--font);
    color: var(--c-text);
    width: 100%;
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
    transition: border-color 0.2s;
  }
  .vform__input:focus { border-color: var(--c-text); }

  .vform__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .vform__submit {
    align-self: flex-start;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--c-text);
    background: none;
    padding: 0.65rem 1.4rem;
    font-size: 0.7rem;
    font-family: var(--font);
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--c-text);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    margin-top: 0.25rem;
  }
  .vform__submit:hover {
    background: var(--c-text);
    color: var(--c-bg);
  }
  .vform__arrow {
    font-size: 0.85rem;
    transition: transform 0.2s;
  }
  .vform__submit:hover .vform__arrow { transform: translateX(3px); }

  /* ─── Checkbox newsletter ─── */
  .vform__check {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    margin-top: 0.25rem;
  }
  .vform__check-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .vform__check-box {
    width: 14px;
    height: 14px;
    border: 1px solid var(--c-border);
    flex-shrink: 0;
    position: relative;
    transition: background 0.15s, border-color 0.15s;
  }
  .vform__check-input:checked + .vform__check-box {
    background: var(--c-text);
    border-color: var(--c-text);
  }
  .vform__check-input:checked + .vform__check-box::after {
    content: '';
