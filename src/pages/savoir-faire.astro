---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import bandeauData from "../content/pages/savoir-faire-bandeau.json";
import sectionsData from "../content/pages/savoir-faire-sections.json";
import parametres from "../content/parametres/index.json";
import RichText from "../components/RichText.tsx";
import { FONTS } from "../layouts/Layout.astro";
import { optimizePath } from "../lib/image";

const styleMap: Record<string, string> = {
  normal: 'normal',
  bold: 'bold',
  italic: 'italic',
};

// Bandeau styles
const bandeauFontKey = bandeauData.font && bandeauData.font !== 'inherit' && FONTS[bandeauData.font] ? bandeauData.font : null;
const bandeauFont = bandeauFontKey ? FONTS[bandeauFontKey].family : null;
const bandeauFontUrl = bandeauFontKey ? FONTS[bandeauFontKey].url : null;
const bandeauColor = bandeauData.text_color || '#1A1A18';
const bandeauLabelStyle = styleMap[bandeauData.label_style] || 'bold';
const bandeauTitreStyle = styleMap[bandeauData.titre_style] || 'normal';
const bandeauSousTitreStyle = styleMap[bandeauData.sous_titre_style] || 'normal';

const pageLabel    = bandeauData.page_label     || "EXPERTISES";
const pageTitre    = bandeauData.page_titre     || "Savoir Faire";
const pageSousTitre = bandeauData.page_sous_titre || "Cinq domaines d'expertise complémentaires, un fil conducteur : l'exigence et la passion du travail bien fait.";
const formTitre    = bandeauData.form_titre     || "Parlons de votre projet";
const formIntro1   = bandeauData.form_intro_1   || [{ type: "paragraph", children: [{ text: "Vous avez un besoin précis — sourcing, scénographie, logistique, valorisation de collection ? Décrivez-nous votre mission et nous reviendrons vers vous avec une proposition adaptée." }] }];
const formIntro2   = bandeauData.form_intro_2   || [{ type: "paragraph", children: [{ text: "Ce formulaire est dédié aux demandes de prestation et de collaboration. Pour une visite du Village ou une question générale, utilisez le formulaire de contact." }] }];

const fallbackSets = [
  ["/images/projet1.jpg", "/images/projet2.webp", "/images/projet3.jpg"],
  ["/images/projet2.webp", "/images/projet3.jpg", "/images/projet4.webp"],
  ["/images/projet3.jpg", "/images/projet4.webp", "/images/projet1.jpg"],
  ["/images/projet4.webp", "/images/projet1.jpg", "/images/projet2.webp"],
  ["/images/projet1.jpg", "/images/projet3.jpg", "/images/projet2.webp"],
];

const expertises = (sectionsData.sections || []).map((s: any, i: number) => {
  const fontKey = s.font && s.font !== 'inherit' && FONTS[s.font] ? s.font : null;
  return {
    id: s.title ? s.title.toLowerCase().replace(/[^a-z0-9]+/g, '-') : `section-${i}`,
    label: s.label || '',
    title: s.title || '',
    intro: s.intro || [],
    body: (s.paragraphs || []).filter(Boolean),
    images: (s.images || []).map((src: string) => optimizePath(src)),
    fallbackImages: fallbackSets[i % fallbackSets.length],
    font: fontKey ? FONTS[fontKey].family : null,
    fontUrl: fontKey ? FONTS[fontKey].url : null,
    color: s.text_color || '#1A1A18',
    labelStyle: styleMap[s.label_style] || 'bold',
    titleStyle: styleMap[s.title_style] || 'normal',
    textStyle: styleMap[s.text_style] || 'normal',
  };
});
---

<Layout title={`Savoir Faire — ${parametres.nom_site}`} description="Les expertises de l'Agence Atipics">
  <Header />
  <main style="padding-top: var(--nav-h);">

    <!-- Header page -->
    <section class="page-head" style={`${bandeauFont ? `font-family: ${bandeauFont};` : ''}--bandeau-color:${bandeauColor};--bandeau-label-weight:${bandeauLabelStyle === 'bold' ? '700' : '400'};--bandeau-label-style:${bandeauLabelStyle === 'italic' ? 'italic' : 'normal'};--bandeau-titre-weight:${bandeauTitreStyle === 'bold' ? '700' : '200'};--bandeau-titre-style:${bandeauTitreStyle === 'italic' ? 'italic' : 'normal'};--bandeau-soustitre-weight:${bandeauSousTitreStyle === 'bold' ? '600' : '400'};--bandeau-soustitre-style:${bandeauSousTitreStyle === 'italic' ? 'italic' : 'normal'}`}>
      {bandeauFontUrl && <link rel="stylesheet" href={bandeauFontUrl} />}
      <div class="container">
        <div class="label-row">
          <span class="section-stamp">{pageLabel}</span>
          <div class="rule"></div>
        </div>
        <h1 class="page-head__title">{pageTitre}</h1>
        <p class="page-head__sub">{pageSousTitre}</p>
      </div>
    </section>

    <!-- Expertises -->
    {expertises.map((e, i) => (
      <section class:list={["expertise-block", { "expertise-block--alt": i % 2 !== 0 }]} id={e.id} style={`${e.font ? `font-family: ${e.font};` : ''}--section-color:${e.color};--section-label-weight:${e.labelStyle === 'bold' ? '700' : '400'};--section-label-style:${e.labelStyle === 'italic' ? 'italic' : 'normal'};--section-titre-weight:${e.titleStyle === 'bold' ? '700' : '300'};--section-titre-style:${e.titleStyle === 'italic' ? 'italic' : 'normal'};--section-text-weight:${e.textStyle === 'bold' ? '600' : '400'};--section-text-style:${e.textStyle === 'italic' ? 'italic' : 'normal'}`}>
          {e.fontUrl && <link rel="stylesheet" href={e.fontUrl} />}
        <div class="container">
          <div class="label-row">
            <span class="section-stamp">{e.label}</span>
            <div class="rule"></div>
          </div>
          <div class="expertise-grid">
            <div class="expertise-text">
              <h2 class="expertise-title">{e.title}</h2>
              <RichText document={e.intro} className="expertise-intro" />
              {e.body.map((p: any) => <RichText document={p} className="expertise-p" />)}
            </div>
            <div class="expertise-carousel" data-carousel>
              <div class="ecarousel__track" data-track>
                {(e.images.length > 0 ? e.images : e.fallbackImages).map((img: string, j: number) => (
                  <div class="ecarousel__slide" aria-hidden={j !== 0}>
                    <img src={optimizePath(img)} alt={`${e.title} ${j + 1}`} class="ecarousel__img" loading="lazy" />
                  </div>
                ))}
              </div>
              <button class="ecarousel__btn ecarousel__btn--prev" aria-label="Précédent">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <button class="ecarousel__btn ecarousel__btn--next" aria-label="Suivant">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="ecarousel__counter" data-counter></div>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Formulaire expertise / mission -->
    <section class="form-section">
      <div class="container">
        <div class="label-row">
          <span class="section-stamp">CONFIER UNE MISSION</span>
          <div class="rule"></div>
        </div>
        <div class="form-layout">
          <div class="form-intro">
            <h2 class="form-intro__title">{formTitre}</h2>
            <RichText document={formIntro1} className="form-intro__text" />
            <RichText document={formIntro2} className="form-intro__text" />
            <p class="form-intro__text">Contact direct : <a href={`mailto:${parametres.email}`} class="form-intro__link">{parametres.email}</a></p>
          </div>
          <form class="sf-form" name="savoir-faire-mission" method="POST">
            <div class="sf-row">
              <div class="sf-group">
                <label class="sf-label" for="sf-nom">NOM *</label>
                <input class="sf-input" type="text" id="sf-nom" name="nom" required autocomplete="name" />
              </div>
              <div class="sf-group">
                <label class="sf-label" for="sf-societe">SOCIÉTÉ / STRUCTURE</label>
                <input class="sf-input" type="text" id="sf-societe" name="societe" autocomplete="organization" />
              </div>
            </div>
            <div class="sf-row">
              <div class="sf-group">
                <label class="sf-label" for="sf-email">EMAIL *</label>
                <input class="sf-input" type="email" id="sf-email" name="email" required autocomplete="email" />
              </div>
              <div class="sf-group">
                <label class="sf-label" for="sf-tel">TÉLÉPHONE</label>
                <input class="sf-input" type="tel" id="sf-tel" name="telephone" autocomplete="tel" />
              </div>
            </div>
            <div class="sf-group">
              <label class="sf-label" for="sf-expertise">DOMAINE D'EXPERTISE CONCERNÉ</label>
              <select class="sf-input sf-select" id="sf-expertise" name="expertise">
                <option value="">— Sélectionner —</option>
                <option value="curation">Curation et Sourcing</option>
                <option value="conciergerie">Conciergerie et Propriété</option>
                <option value="events">Events et Scénographie</option>
                <option value="intendance">Intendance et Logistique</option>
                <option value="valorisation">Valorisation de Collections</option>
                <option value="autre">Autre / Plusieurs domaines</option>
              </select>
            </div>
            <div class="sf-group">
              <label class="sf-label" for="sf-budget">BUDGET ENVISAGÉ</label>
              <select class="sf-input sf-select" id="sf-budget" name="budget">
                <option value="">— Sélectionner —</option>
                <option value="<5k">Moins de 5 000 €</option>
                <option value="5-15k">5 000 – 15 000 €</option>
                <option value="15-50k">15 000 – 50 000 €</option>
                <option value=">50k">Plus de 50 000 €</option>
                <option value="nc">Non communiqué</option>
              </select>
            </div>
            <div class="sf-group">
              <label class="sf-label" for="sf-mission">DESCRIPTION DE LA MISSION *</label>
              <textarea class="sf-input sf-textarea" id="sf-mission" name="mission" rows="5" required placeholder="Décrivez votre projet, le contexte, les contraintes et vos attentes..."></textarea>
            </div>
            <div class="sf-check-group">
              <label class="sf-check">
                <input type="checkbox" name="newsletter" value="oui" class="sf-check__input" />
                <span class="sf-check__box"></span>
                <span class="sf-check__label">Je souhaite recevoir la newsletter Atipics — actualités, découvertes et nouvelles missions.</span>
              </label>
            </div>
            <button type="submit" class="sf-submit">
              ENVOYER LA DEMANDE <span aria-hidden="true">→</span>
            </button>
          </form>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('[data-carousel]').forEach((carousel) => {
    const track   = carousel.querySelector('[data-track]') as HTMLElement;
    const slides  = Array.from(track.querySelectorAll('.ecarousel__slide')) as HTMLElement[];
    const prevBtn = carousel.querySelector('.ecarousel__btn--prev') as HTMLButtonElement;
    const nextBtn = carousel.querySelector('.ecarousel__btn--next') as HTMLButtonElement;
    const counter = carousel.querySelector('[data-counter]') as HTMLElement;
    let current = 0;

    function go(n: number) {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      current = ((n % slides.length) + slides.length) % slides.length;
      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      if (counter) counter.textContent = `${current + 1} / ${slides.length}`;
    }

    // init
    slides[0].classList.add('is-active');
    if (counter) counter.textContent = `1 / ${slides.length}`;

    prevBtn.addEventListener('click', () => go(current - 1));
    nextBtn.addEventListener('click', () => go(current + 1));
  });
</script>

<style>
  /* ─── Helpers ─── */
  .label-row {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    margin-bottom: var(--sp-md);
  }
  .section-stamp {
    font-size: 0.68rem;
    font-weight: var(--bandeau-label-weight, 700);
    font-style: var(--bandeau-label-style, normal);
    letter-spacing: 0.18em;
    color: var(--bandeau-color, var(--c-muted));
    white-space: nowrap;
    flex-shrink: 0;
  }
  .rule {
    flex: 1;
    height: 1px;
    background: var(--c-border);
  }

  /* ─── Page head ─── */
  .page-head {
    padding-top: var(--sp-lg);
    padding-bottom: var(--sp-lg);
    border-bottom: 1px solid var(--c-border);
  }
  .page-head__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: var(--bandeau-titre-weight, 200);
    font-style: var(--bandeau-titre-style, normal);
    letter-spacing: -0.03em;
    line-height: 0.92;
    margin-bottom: var(--sp-sm);
    color: var(--bandeau-color, inherit);
  }
  .page-head__sub {
    font-size: var(--text-xs);
    font-weight: var(--bandeau-soustitre-weight, 400);
    font-style: var(--bandeau-soustitre-style, normal);
    color: var(--bandeau-color, var(--c-muted));
    line-height: 1.75;
    max-width: 52ch;
    opacity: 0.8;
  }

  /* ─── Expertise block ─── */
  .expertise-block {
    padding-block: var(--sp-xl);
    border-bottom: 1px solid var(--c-border);
  }
  .expertise-block--alt { background: var(--c-surface); }
  .expertise-block:last-of-type { border-bottom: none; }

  .expertise-grid {
    display: grid;
    grid-template-columns: 1fr 52%;
    gap: var(--sp-xl);
    align-items: start;
  }

  .expertise-title {
    font-size: var(--text-xl);
    font-weight: var(--section-titre-weight, 300);
    font-style: var(--section-titre-style, normal);
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-sm);
    color: var(--section-color, inherit);
  }
  .expertise-intro {
    font-size: var(--text-xs);
    font-style: italic;
    color: var(--section-color, var(--c-muted));
    margin-bottom: var(--sp-sm);
    line-height: 1.7;
    opacity: 0.8;
  }
  .expertise-p {
    font-size: var(--text-xs);
    font-weight: var(--section-text-weight, 400);
    font-style: var(--section-text-style, normal);
    color: var(--section-color, var(--c-muted));
    line-height: 1.85;
    margin-bottom: 0.6rem;
    max-width: 46ch;
  }

  /* ─── Expertise carousel ─── */
  .expertise-carousel {
    position: relative;
    overflow: hidden;
  }
  .ecarousel__track {
    position: relative;
    width: 100%;
  }
  .ecarousel__slide {
    display: none;
  }
  .ecarousel__slide.is-active {
    display: block;
  }
  .ecarousel__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  /* flèches — visibles au survol du carousel */
  .ecarousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(250,250,248,0.85);
    border: 1px solid var(--c-border);
    color: var(--c-text);
    width: 2.4rem;
    height: 2.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, background 0.15s;
    z-index: 2;
    backdrop-filter: blur(3px);
  }
  .expertise-carousel:hover .ecarousel__btn { opacity: 1; }
  .ecarousel__btn:hover { background: var(--c-bg); }
  .ecarousel__btn--prev { left: 0.5rem; }
  .ecarousel__btn--next { right: 0.5rem; }

  .ecarousel__counter {
    position: absolute;
    bottom: 0.5rem;
    right: 0.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.8);
    background: rgba(0,0,0,0.35);
    padding: 0.15rem 0.4rem;
    pointer-events: none;
  }

  /* ─── CTA ─── */
  .cta-section {
    padding-block: var(--sp-xl);
    border-top: 1px solid var(--c-border);
  }
  .cta-text {
    font-size: var(--text-xs);
    color: var(--c-muted);
    margin-bottom: var(--sp-md);
    max-width: 44ch;
    line-height: 1.75;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--c-text);
    padding: 0.65rem 1.4rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--c-text);
    background: none;
    transition: background 0.2s, color 0.2s;
    cursor: pointer;
    text-decoration: none;
  }
  .cta-btn:hover {
    background: var(--c-text);
    color: var(--c-bg);
  }

  /* ─── Form section ─── */
  .form-section {
    padding-block: var(--sp-xl);
    border-top: 1px solid var(--c-border);
  }
  .form-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-xl);
    align-items: start;
  }
  .form-intro__title {
    font-size: var(--text-xl);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-sm);
  }
  .form-intro__text {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.8;
    margin-bottom: var(--sp-sm);
    max-width: 38ch;
  }
  .form-intro__text strong { color: var(--c-text); font-weight: 600; }
  .form-intro__link {
    color: var(--c-text);
    border-bottom: 1px solid var(--c-border);
    transition: border-color 0.2s;
  }
  .form-intro__link:hover { border-bottom-color: var(--c-text); }

  /* ─── Form ─── */
  .sf-form { display: flex; flex-direction: column; gap: var(--sp-sm); }
  .sf-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-sm); }
  .sf-group { display: flex; flex-direction: column; gap: 0.35rem; }
  .sf-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--c-muted);
  }
  .sf-input {
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    padding: 0.6rem 0.75rem;
    font-size: var(--text-xs);
    font-family: var(--font);
    color: var(--c-text);
    width: 100%;
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
    transition: border-color 0.2s;
  }
  .sf-input:focus { border-color: var(--c-text); }
  .sf-select { cursor: pointer; }
  .sf-textarea { resize: vertical; min-height: 120px; }

  /* ─── Checkbox newsletter ─── */
  .sf-check-group { padding-top: 0.25rem; }
  .sf-check {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    cursor: pointer;
  }
  .sf-check__input { position: absolute; opacity: 0; width: 0; height: 0; }
  .sf-check__box {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    margin-top: 0.1rem;
    transition: background 0.15s, border-color 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sf-check__input:checked + .sf-check__box {
    background: var(--c-text);
    border-color: var(--c-text);
  }
  .sf-check__input:checked + .sf-check__box::after {
    content: '';
    display: block;
    width: 0.35rem;
    height: 0.6rem;
    border: 2px solid var(--c-bg);
    border-top: none;
    border-left: none;
    transform: rotate(45deg) translateY(-1px);
  }
  .sf-check__label {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.6;
  }

  /* ─── Submit ─── */
  .sf-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--c-text);
    background: none;
    padding: 0.65rem 1.4rem;
    font-size: 0.68rem;
    font-family: var(--font);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--c-text);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    margin-top: 0.25rem;
  }
  .sf-submit:hover { background: var(--c-text); color: var(--c-bg); }

  @media (max-width: 900px) {
    .expertise-grid { grid-template-columns: 1fr; }
    .expertise-p { max-width: 100%; }
    .ecarousel__btn { opacity: 1; }
    .form-layout { grid-template-columns: 1fr; gap: var(--sp-md); }
    .form-intro__text { max-width: 100%; }
    .sf-row { grid-template-columns: 1fr; }
  }
</style>
