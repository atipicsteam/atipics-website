---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import cms from "../content/pages/savoir-faire.json";
import parametres from "../content/parametres/index.json";
import RichText from "../components/RichText.tsx";

const imagesBySection: Record<string, string[]> = {
  curation: cms.curation_images || [],
  conciergerie: cms.conciergerie_images || [],
  events: cms.events_images || [],
  intendance: cms.intendance_images || [],
  valorisation: cms.valorisation_images || [],
};


const pageLabel    = cms.page_label     || "EXPERTISES";
const pageTitre    = cms.page_titre     || "Savoir Faire";
const pageSousTitre = cms.page_sous_titre || "Cinq domaines d'expertise complémentaires, un fil conducteur : l'exigence et la passion du travail bien fait.";
const formTitre    = cms.form_titre     || "Parlons de votre projet";
const formIntro1   = cms.form_intro_1   || "Vous avez un besoin précis — sourcing, scénographie, logistique, valorisation de collection ? Décrivez-nous votre mission et nous reviendrons vers vous avec une proposition adaptée.";
const formIntro2   = cms.form_intro_2   || "Ce formulaire est dédié aux demandes de <strong>prestation et de collaboration</strong>. Pour une visite du Village ou une question générale, utilisez le formulaire de contact.";

const expertises = [
  {
    id: "curation",
    label: cms.curation_label || "CURATION ET SOURCING",
    title: cms.curation_titre || "Curation et Sourcing",
    intro: cms.curation_intro || "L'art de trouver ce qui n'existe pas encore sur le marché.",
    body: [
      cms.curation_p1 || "Notre mission de curation va bien au-delà de la simple sélection. Nous fouillons marchés, ventes aux enchères, ateliers d'artisans et collections privées pour dénicher les pièces qui feront la différence dans votre projet.",
      cms.curation_p2 || "Mobilier ancien et contemporain, objets de curiosité, textiles rares, œuvres d'art — notre regard transversal nous permet d'assembler des univers cohérents et singuliers, porteurs d'une identité forte.",
    ],
    fallbackImages: ["/images/projet1.jpg", "/images/projet2.webp", "/images/projet3.jpg"],
  },
  {
    id: "conciergerie",
    label: cms.conciergerie_label || "CONCIERGERIE ET PROPRIÉTÉ",
    title: cms.conciergerie_titre || "Conciergerie et Propriété",
    intro: cms.conciergerie_intro || "Un interlocuteur unique pour la gestion complète de votre patrimoine.",
    body: [
      cms.conciergerie_p1 || "Nous prenons en charge la gestion de vos espaces et de vos biens avec la même exigence que si c'était les nôtres. De l'entretien courant à la coordination de travaux, nous orchestrons chaque détail.",
      cms.conciergerie_p2 || "Disponibles, réactifs et discrets, nous sommes votre relais de confiance sur place, garantissant que votre propriété est toujours dans un état impeccable.",
    ],
    fallbackImages: ["/images/projet2.webp", "/images/projet3.jpg", "/images/projet4.webp"],
  },
  {
    id: "events",
    label: cms.events_label || "EVENTS ET SCÉNOGRAPHIE",
    title: cms.events_titre || "Events et Scénographie",
    intro: cms.events_intro || "Transformer un espace en expérience mémorable.",
    body: [
      cms.events_p1 || "Chaque événement est une opportunité de raconter une histoire. Nous concevons des scénographies qui mêlent mobilier, lumière, matière et narration pour créer des atmosphères inoubliables.",
      cms.events_p2 || "Soirées privées, lancements de marque, expositions, salons — notre équipe maîtrise toutes les échelles et tous les types de configurations, des plus intimes aux plus spectaculaires.",
    ],
    fallbackImages: ["/images/projet3.jpg", "/images/projet4.webp", "/images/projet1.jpg"],
  },
  {
    id: "intendance",
    label: cms.intendance_label || "INTENDANCE ET LOGISTIQUE",
    title: cms.intendance_titre || "Intendance et Logistique",
    intro: cms.intendance_intro || "Les coulisses parfaites pour que l'essentiel brille.",
    body: [
      cms.intendance_p1 || "La logistique est souvent le parent pauvre des projets ambitieux. Chez Atipics, nous en avons fait une spécialité. Transport, emballage, stockage, installation — nous gérons l'invisible pour que le visible soit irréprochable.",
      cms.intendance_p2 || "Notre réseau de transporteurs spécialisés, d'emballeurs experts et de techniciens d'installation garantit que chaque pièce arrive à destination dans les conditions idéales.",
    ],
    fallbackImages: ["/images/projet4.webp", "/images/projet1.jpg", "/images/projet2.webp"],
  },
  {
    id: "valorisation",
    label: cms.valorisation_label || "VALORISATION DE COLLECTIONS",
    title: cms.valorisation_titre || "Valorisation de Collections",
    intro: cms.valorisation_intro || "Révéler le potentiel de ce que vous possédez déjà.",
    body: [
      cms.valorisation_p1 || "Vous possédez une collection, un héritage, un ensemble de pièces dont vous ne savez que faire ? Nous intervenons pour inventorier, expertiser, documenter et valoriser ce patrimoine.",
      cms.valorisation_p2 || "Qu'il s'agisse de le mettre en scène dans votre intérieur, de le proposer à la vente dans les meilleures conditions ou de le transmettre, nous vous accompagnons à chaque étape avec rigueur et passion.",
    ],
    fallbackImages: ["/images/projet1.jpg", "/images/projet3.jpg", "/images/projet2.webp"],
  },
];
---

<Layout title={`Savoir Faire — ${parametres.nom_site}`} description="Les expertises de l'Agence Atipics">
  <Header />
  <main style="padding-top: var(--nav-h);">

    <!-- Header page -->
    <section class="page-head">
      <div class="container">
        <div class="label-row">
          <span class="section-stamp">{pageLabel}</span>
          <div class="rule"></div>
        </div>
        <h1 class="page-head__title">{pageTitre}</h1>
        <p class="page-head__sub">{pageSousTitre}</p>
      </div>
    </section>

    <!-- Expertises -->
    {expertises.map((e, i) => (
      <section class:list={["expertise-block", { "expertise-block--alt": i % 2 !== 0 }]} id={e.id}>
        <div class="container">
          <div class="label-row">
            <span class="section-stamp">{e.label}</span>
            <div class="rule"></div>
          </div>
          <div class="expertise-grid">
            <div class="expertise-text">
              <h2 class="expertise-title">{e.title}</h2>
              <RichText document={e.intro} className="expertise-intro" />
              {e.body.map((p) => <RichText document={p} className="expertise-p" />)}
            </div>
            <div class="expertise-carousel" data-carousel>
              <div class="ecarousel__track" data-track>
                {(imagesBySection[e.id]?.length > 0 ? imagesBySection[e.id] : e.fallbackImages).map((img: string, j: number) => (
                  <div class="ecarousel__slide" aria-hidden={j !== 0}>
                    <img src={img} alt={`${e.title} ${j + 1}`} class="ecarousel__img" loading="lazy" />
                  </div>
                ))}
              </div>
              <button class="ecarousel__btn ecarousel__btn--prev" aria-label="Précédent">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <button class="ecarousel__btn ecarousel__btn--next" aria-label="Suivant">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="ecarousel__counter" data-counter></div>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Formulaire expertise / mission -->
    <section class="form-section">
      <div class="container">
        <div class="label-row">
          <span class="section-stamp">CONFIER UNE MISSION</span>
          <div class="rule"></div>
        </div>
        <div class="form-layout">
          <div class="form-intro">
            <h2 class="form-intro__title">{formTitre}</h2>
            <RichText document={formIntro1} className="form-intro__text" />
            <RichText document={formIntro2} className="form-intro__text" />
            <p class="form-intro__text">Contact direct : <a href={`mailto:${parametres.email}`} class="form-intro__link">{parametres.email}</a></p>
          </div>
          <form class="sf-form" name="savoir-faire-mission" method="POST">
            <div class="sf-row">
              <div class="sf-group">
                <label class="sf-label" for="sf-nom">NOM *</label>
                <input class="sf-input" type="text" id="sf-nom" name="nom" required autocomplete="name" />
              </div>
              <div class="sf-group">
                <label class="sf-label" for="sf-societe">SOCIÉTÉ / STRUCTURE</label>
                <input class="sf-input" type="text" id="sf-societe" name="societe" autocomplete="organization" />
              </div>
            </div>
            <div class="sf-row">
              <div class="sf-group">
                <label class="sf-label" for="sf-email">EMAIL *</label>
                <input class="sf-input" type="email" id="sf-email" name="email" required autocomplete="email" />
              </div>
              <div class="sf-group">
                <label class="sf-label" for="sf-tel">TÉLÉPHONE</label>
                <input class="sf-input" type="tel" id="sf-tel" name="telephone" autocomplete="tel" />
              </div>
            </div>
            <div class="sf-group">
              <label class="sf-label" for="sf-expertise">DOMAINE D'EXPERTISE CONCERNÉ</label>
              <select class="sf-input sf-select" id="sf-expertise" name="expertise">
                <option value="">— Sélectionner —</option>
                <option value="curation">Curation et Sourcing</option>
                <option value="conciergerie">Conciergerie et Propriété</option>
                <option value="events">Events et Scénographie</option>
                <option value="intendance">Intendance et Logistique</option>
                <option value="valorisation">Valorisation de Collections</option>
                <option value="autre">Autre / Plusieurs domaines</option>
              </select>
            </div>
            <div class="sf-group">
              <label class="sf-label" for="sf-budget">BUDGET ENVISAGÉ</label>
              <select class="sf-input sf-select" id="sf-budget" name="budget">
                <option value="">— Sélectionner —</option>
                <option value="<5k">Moins de 5 000 €</option>
                <option value="5-15k">5 000 – 15 000 €</option>
                <option value="15-50k">15 000 – 50 000 €</option>
                <option value=">50k">Plus de 50 000 €</option>
                <option value="nc">Non communiqué</option>
              </select>
            </div>
            <div class="sf-group">
              <label class="sf-label" for="sf-mission">DESCRIPTION DE LA MISSION *</label>
              <textarea class="sf-input sf-textarea" id="sf-mission" name="mission" rows="5" required placeholder="Décrivez votre projet, le contexte, les contraintes et vos attentes..."></textarea>
            </div>
            <div class="sf-check-group">
              <label class="sf-check">
                <input type="checkbox" name="newsletter" value="oui" class="sf-check__input" />
                <span class="sf-check__box"></span>
                <span class="sf-check__label">Je souhaite recevoir la newsletter Atipics — actualités, découvertes et nouvelles missions.</span>
              </label>
            </div>
            <button type="submit" class="sf-submit">
              ENVOYER LA DEMANDE <span aria-hidden="true">→</span>
            </button>
          </form>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll('[data-carousel]').forEach((carousel) => {
    const track   = carousel.querySelector('[data-track]') as HTMLElement;
    const slides  = Array.from(track.querySelectorAll('.ecarousel__slide')) as HTMLElement[];
    const prevBtn = carousel.querySelector('.ecarousel__btn--prev') as HTMLButtonElement;
    const nextBtn = carousel.querySelector('.ecarousel__btn--next') as HTMLButtonElement;
    const counter = carousel.querySelector('[data-counter]') as HTMLElement;
    let current = 0;

    function go(n: number) {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      current = ((n % slides.length) + slides.length) % slides.length;
      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      if (counter) counter.textContent = `${current + 1} / ${slides.length}`;
    }

    // init
    slides[0].classList.add('is-active');
    if (counter) counter.textContent = `1 / ${slides.length}`;

    prevBtn.addEventListener('click', () => go(current - 1));
    nextBtn.addEventListener('click', () => go(current + 1));
  });
</script>

<style>
  /* ─── Helpers ─── */
  .label-row {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    margin-bottom: var(--sp-md);
  }
  .section-stamp {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .rule {
    flex: 1;
    height: 1px;
    background: var(--c-border);
  }

  /* ─── Page head ─── */
  .page-head {
    padding-top: var(--sp-lg);
    padding-bottom: var(--sp-lg);
    border-bottom: 1px solid var(--c-border);
  }
  .page-head__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    line-height: 0.92;
    margin-bottom: var(--sp-sm);
  }
  .page-head__sub {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.75;
    max-width: 52ch;
  }

  /* ─── Expertise block ─── */
  .expertise-block {
    padding-block: var(--sp-xl);
    border-bottom: 1px solid var(--c-border);
  }
  .expertise-block--alt { background: var(--c-surface); }
  .expertise-block:last-of-type { border-bottom: none; }

  .expertise-grid {
    display: grid;
    grid-template-columns: 1fr 52%;
    gap: var(--sp-xl);
    align-items: start;
  }

  .expertise-title {
    font-size: var(--text-xl);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-sm);
  }
  .expertise-intro {
    font-size: var(--text-xs);
    font-style: italic;
    color: var(--c-muted);
    margin-bottom: var(--sp-sm);
    line-height: 1.7;
  }
  .expertise-p {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.85;
    margin-bottom: 0.6rem;
    max-width: 46ch;
  }

  /* ─── Expertise carousel ─── */
  .expertise-carousel {
    position: relative;
    overflow: hidden;
  }
  .ecarousel__track {
    position: relative;
    width: 100%;
  }
  .ecarousel__slide {
    display: none;
  }
  .ecarousel__slide.is-active {
    display: block;
  }
  .ecarousel__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  /* flèches — visibles au survol du carousel */
  .ecarousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(250,250,248,0.85);
    border: 1px solid var(--c-border);
    color: var(--c-text);
    width: 2.4rem;
    height: 2.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, background 0.15s;
    z-index: 2;
    backdrop-filter: blur(3px);
  }
  .expertise-carousel:hover .ecarousel__btn { opacity: 1; }
  .ecarousel__btn:hover { background: var(--c-bg); }
  .ecarousel__btn--prev { left: 0.5rem; }
  .ecarousel__btn--next { right: 0.5rem; }

  .ecarousel__counter {
    position: absolute;
    bottom: 0.5rem;
    right: 0.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.8);
    background: rgba(0,0,0,0.35);
    padding: 0.15rem 0.4rem;
    pointer-events: none;
  }

  /* ─── CTA ─── */
  .cta-section {
    padding-block: var(--sp-xl);
    border-top: 1px solid var(--c-border);
  }
  .cta-text {
    font-size: var(--text-xs);
    color: var(--c-muted);
    margin-bottom: var(--sp-md);
    max-width: 44ch;
    line-height: 1.75;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--c-text);
    padding: 0.65rem 1.4rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--c-text);
    background: none;
    transition: background 0.2s, color 0.2s;
    cursor: pointer;
    text-decoration: none;
  }
  .cta-btn:hover {
    background: var(--c-text);
    color: var(--c-bg);
  }

  /* ─── Form section ─── */
  .form-section {
    padding-block: var(--sp-xl);
    border-top: 1px solid var(--c-border);
  }
  .form-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-xl);
    align-items: start;
  }
  .form-intro__title {
    font-size: var(--text-xl);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-sm);
  }
  .form-intro__text {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.8;
    margin-bottom: var(--sp-sm);
    max-width: 38ch;
  }
  .form-intro__text strong { color: var(--c-text); font-weight: 600; }
  .form-intro__link {
    color: var(--c-text);
    border-bottom: 1px solid var(--c-border);
    transition: border-color 0.2s;
  }
  .form-intro__link:hover { border-bottom-color: var(--c-text); }

  /* ─── Form ─── */
  .sf-form { display: flex; flex-direction: column; gap: var(--sp-sm); }
  .sf-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-sm); }
  .sf-group { display: flex; flex-direction: column; gap: 0.35rem; }
  .sf-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--c-muted);
  }
  .sf-input {
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    padding: 0.6rem 0.75rem;
    font-size: var(--text-xs);
    font-family: var(--font);
    color: var(--c-text);
    width: 100%;
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
    transition: border-color 0.2s;
  }
  .sf-input:focus { border-color: var(--c-text); }
  .sf-select { cursor: pointer; }
  .sf-textarea { resize: vertical; min-height: 120px; }

  /* ─── Checkbox newsletter ─── */
  .sf-check-group { padding-top: 0.25rem; }
  .sf-check {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    cursor: pointer;
  }
  .sf-check__input { position: absolute; opacity: 0; width: 0; height: 0; }
  .sf-check__box {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    margin-top: 0.1rem;
    transition: background 0.15s, border-color 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sf-check__input:checked + .sf-check__box {
    background: var(--c-text);
    border-color: var(--c-text);
  }
  .sf-check__input:checked + .sf-check__box::after {
    content: '';
    display: block;
    width: 0.35rem;
    height: 0.6rem;
    border: 2px solid var(--c-bg);
    border-top: none;
    border-left: none;
    transform: rotate(45deg) translateY(-1px);
  }
  .sf-check__label {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.6;
  }

  /* ─── Submit ─── */
  .sf-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--c-text);
    background: none;
    padding: 0.65rem 1.4rem;
    font-size: 0.68rem;
    font-family: var(--font);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--c-text);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    margin-top: 0.25rem;
  }
  .sf-submit:hover { background: var(--c-text); color: var(--c-bg); }

  @media (max-width: 900px) {
    .expertise-grid { grid-template-columns: 1fr; }
    .expertise-p { max-width: 100%; }
    .ecarousel__btn { opacity: 1; }
    .form-layout { grid-template-columns: 1fr; gap: var(--sp-md); }
    .form-intro__text { max-width: 100%; }
    .sf-row { grid-template-columns: 1fr; }
  }
</style>
