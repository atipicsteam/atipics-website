---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.config";

const projets = site.projets;
---

<Layout title={`Projets — ${site.name}`} description="Réalisations et projets de l'Agence Atipics">
  <Header />
  <main style="padding-top: var(--nav-h);">

    <!-- En-tête -->
    <section class="page-header">
      <div class="container">
        <div class="page-header__row">
          <span class="page-label">PROJETS</span>
          <div class="page-rule"></div>
        </div>
      </div>
    </section>

    <!-- Grille projets -->
    <section class="projets">
      <div class="container">
        <div class="projets__grid" id="projets-grid">
          {projets.map((p, i) => (
            <article
              class="proj-card"
              data-index={i}
              role="button"
              tabindex="0"
              aria-label={`Ouvrir ${p.title}`}
            >
              <div class="proj-card__media">
                <img src={p.cover} alt={p.title} class="proj-card__img" loading="lazy" />
              </div>
              <div class="proj-card__info">
                <span class="proj-card__cat">{p.category} — {p.year}</span>
                <h2 class="proj-card__title">{p.title}</h2>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Visionneuse projet" hidden>
  <button class="lightbox__close" id="lb-close" aria-label="Fermer">
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <div class="lightbox__inner">
    <!-- Média principal -->
    <div class="lightbox__stage">
      <button class="lightbox__nav lightbox__nav--prev" id="lb-prev" aria-label="Précédent">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="lightbox__media-wrap" id="lb-media-wrap">
        <!-- injecté par JS -->
      </div>
      <button class="lightbox__nav lightbox__nav--next" id="lb-next" aria-label="Suivant">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- Miniatures -->
    <div class="lightbox__thumbs" id="lb-thumbs"></div>

    <!-- Infos projet -->
    <div class="lightbox__meta" id="lb-meta"></div>
  </div>
</div>
<div class="lightbox__backdrop" id="lb-backdrop"></div>

<script is:inline define:vars={{ projets }}>
  const lb        = document.getElementById('lightbox');
  const backdrop  = document.getElementById('lb-backdrop');
  const closeBtn  = document.getElementById('lb-close');
  const prevBtn   = document.getElementById('lb-prev');
  const nextBtn   = document.getElementById('lb-next');
  const mediaWrap = document.getElementById('lb-media-wrap');
  const thumbsEl  = document.getElementById('lb-thumbs');
  const metaEl    = document.getElementById('lb-meta');

  let currentProjet = null;
  let currentMedia  = 0;

  // ── helpers ──────────────────────────────────────────
  function mediaEl(m) {
    if (m.type === 'video') {
      const v = document.createElement('video');
      v.src = m.src; v.controls = true; v.autoplay = false;
      v.style.cssText = 'width:100%;aspect-ratio:16/9;background:#000;display:block;';
      return v;
    }
    const img = document.createElement('img');
    img.src = m.src; img.alt = m.alt || '';
    img.style.cssText = 'width:100%;aspect-ratio:16/10;object-fit:cover;display:block;';
    return img;
  }

  function renderMedia(idx) {
    const m = currentProjet.medias[idx];
    mediaWrap.innerHTML = '';
    mediaWrap.appendChild(mediaEl(m));
    currentMedia = idx;
    // counter
    const counter = mediaWrap.parentElement.querySelector('.lb-counter');
    if (counter) counter.textContent = `${idx + 1} / ${currentProjet.medias.length}`;
    // thumbs active
    thumbsEl.querySelectorAll('.lb-thumb').forEach((t, i) => {
      t.classList.toggle('lb-thumb--active', i === idx);
    });
  }

  function openLightbox(projet, startMedia = 0) {
    currentProjet = projet;

    // counter
    const counterEl = document.createElement('span');
    counterEl.className = 'lb-counter';

    // thumbs
    thumbsEl.innerHTML = '';
    projet.medias.forEach((m, i) => {
      const btn = document.createElement('button');
      btn.className = 'lb-thumb';
      btn.setAttribute('aria-label', `Média ${i + 1}`);
      if (m.type === 'video') {
        btn.innerHTML = `<span class="lb-thumb__play">▶</span>`;
      } else {
        const img = document.createElement('img');
        img.src = m.src; img.alt = ''; img.loading = 'lazy';
        btn.appendChild(img);
      }
      btn.addEventListener('click', () => renderMedia(i));
      thumbsEl.appendChild(btn);
    });

    // meta
    metaEl.innerHTML = `
      <p class="lb-meta__title">${projet.title.toUpperCase()}</p>
      <p class="lb-meta__cat">${projet.category} — ${projet.year}</p>
      <p class="lb-meta__desc">${projet.description}</p>
    `;

    renderMedia(startMedia);

    lb.hidden = false;
    backdrop.classList.add('is-visible');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeLightbox() {
    lb.hidden = true;
    backdrop.classList.remove('is-visible');
    document.body.style.overflow = '';
    currentProjet = null;
    // stop any video
    mediaWrap.querySelectorAll('video').forEach(v => v.pause());
  }

  // ── events ───────────────────────────────────────────
  document.querySelectorAll('.proj-card').forEach((card) => {
    const handler = () => {
      const idx = parseInt(card.dataset.index, 10);
      openLightbox(projets[idx]);
    };
    card.addEventListener('click', handler);
    card.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); } });
  });

  closeBtn.addEventListener('click', closeLightbox);
  backdrop.addEventListener('click', closeLightbox);

  prevBtn.addEventListener('click', () => {
    const n = (currentMedia - 1 + currentProjet.medias.length) % currentProjet.medias.length;
    renderMedia(n);
  });
  nextBtn.addEventListener('click', () => {
    const n = (currentMedia + 1) % currentProjet.medias.length;
    renderMedia(n);
  });

  document.addEventListener('keydown', (e) => {
    if (lb.hidden) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') prevBtn.click();
    if (e.key === 'ArrowRight') nextBtn.click();
  });
</script>

<style>
  /* ─── Page header ─── */
  .page-header {
    padding-top: var(--sp-lg);
    padding-bottom: var(--sp-md);
  }
  .page-header__row {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
  }
  .page-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .page-rule {
    flex: 1;
    height: 1px;
    background: var(--c-border);
  }

  /* ─── Grille ─── */
  .projets { padding-bottom: var(--sp-xl); }

  .projets__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-md);
  }

  .proj-card {
    cursor: pointer;
    outline: none;
  }
  .proj-card:focus-visible .proj-card__media {
    outline: 2px solid var(--c-accent);
    outline-offset: 2px;
  }

  .proj-card__media {
    overflow: hidden;
    aspect-ratio: 16/10;
    background: var(--c-surface);
  }
  .proj-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .proj-card:hover .proj-card__img { transform: scale(1.04); }

  .proj-card__info {
    padding-top: 0.6rem;
  }
  .proj-card__cat {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: 0.2rem;
  }
  .proj-card__title {
    font-size: var(--text-base);
    font-weight: 300;
    letter-spacing: -0.01em;
  }

  /* ─── Backdrop ─── */
  .lightbox__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(250,250,248,0.88);
    backdrop-filter: blur(6px);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .lightbox__backdrop.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ─── Lightbox ─── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 201;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-md);
  }
  .lightbox[hidden] { display: none; }

  .lightbox__close {
    position: fixed;
    top: var(--sp-md);
    right: var(--sp-md);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--c-text);
    padding: 0.5rem;
    z-index: 202;
    transition: opacity 0.2s;
  }
  .lightbox__close:hover { opacity: 0.5; }

  .lightbox__inner {
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    width: min(860px, 100%);
    max-height: calc(100vh - 2 * var(--sp-md));
    overflow-y: auto;
    padding: var(--sp-lg);
    box-shadow: 0 24px 64px rgba(0,0,0,0.12);
    position: relative;
    z-index: 202;
  }

  /* ─── Stage ─── */
  .lightbox__stage {
    position: relative;
    margin-bottom: var(--sp-sm);
  }

  .lightbox__media-wrap {
    width: 100%;
    overflow: hidden;
  }

  .lb-media--img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    display: block;
  }
  .lb-media--video {
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
  }

  /* ─── Nav arrows — sur l'image ─── */
  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(250,250,248,0.85);
    border: 1px solid var(--c-border);
    color: var(--c-text);
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
    z-index: 2;
    backdrop-filter: blur(3px);
  }
  .lightbox__nav:hover { background: var(--c-bg); }
  .lightbox__nav--prev { left: 0.5rem; }
  .lightbox__nav--next { right: 0.5rem; }

  /* ─── Thumbnails ─── */
  .lightbox__thumbs {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: var(--sp-sm);
  }

  .lb-thumb {
    width: 72px;
    height: 48px;
    overflow: hidden;
    border: 1px solid var(--c-border);
    background: var(--c-surface);
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s;
    flex-shrink: 0;
  }
  .lb-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lb-thumb--active {
    border-color: var(--c-text);
  }
  .lb-thumb__play {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-size: 1.2rem;
    color: var(--c-muted);
  }

  /* ─── Meta ─── */
  .lightbox__meta {
    border-top: 1px solid var(--c-border);
    padding-top: var(--sp-sm);
  }
  .lb-meta__title {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    margin-bottom: 0.3rem;
  }
  .lb-meta__cat {
    font-size: var(--text-xs);
    color: var(--c-muted);
    margin-bottom: 0.6rem;
  }
  .lb-meta__desc {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.75;
    max-width: 60ch;
  }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .projets__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .projets__grid { grid-template-columns: 1fr; }
    .lightbox__inner { padding: var(--sp-md); }
    .lightbox__nav { display: none; }
  }
</style>
