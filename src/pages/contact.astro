---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.config";
const { contact } = site;
---

<Layout title={`Contact — ${site.name}`} description={contact.intro}>
  <Header />
  <main class="contact-page" style="padding-top: var(--nav-h);">
    <div class="container contact-grid">
      <div class="contact-info">
        <p class="section-label">Nous écrire</p>
        <h1 class="section-title">{contact.title}</h1>
        <div class="divider"></div>
        <p class="section-intro">{contact.intro}</p>
        <div class="contact-details">
          <a href={`mailto:${contact.email}`} class="contact-email">{contact.email}</a>
          <span class="contact-address">{contact.address}</span>
        </div>
      </div>

      <form class="form" name="contact" method="POST">
        <div class="form__group">
          <label class="form__label" for="name">Nom</label>
          <input class="form__input" type="text" id="name" name="name" required autocomplete="name" />
        </div>
        <div class="form__group">
          <label class="form__label" for="email">Email</label>
          <input class="form__input" type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="form__group">
          <label class="form__label" for="sujet">Sujet</label>
          <input class="form__input" type="text" id="sujet" name="sujet" />
        </div>
        <div class="form__group">
          <label class="form__label" for="message">Message</label>
          <textarea class="form__input form__input--textarea" id="message" name="message" rows="6" required></textarea>
        </div>
        <button type="submit" class="form__submit">Envoyer</button>
      </form>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .contact-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-xl);
    align-items: start;
    padding-block: var(--sp-xl);
    flex: 1;
  }

  .contact-details {
    margin-top: var(--sp-lg);
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
  }

  .contact-email {
    font-size: var(--text-lg);
    color: var(--c-accent);
    transition: opacity 0.2s;
  }
  .contact-email:hover { opacity: 0.7; }

  .contact-address {
    font-size: var(--text-sm);
    color: var(--c-muted);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-muted);
  }

  .form__input {
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    padding: 0.75rem var(--sp-sm);
    font-size: var(--text-base);
    font-family: var(--font);
    color: var(--c-text);
    width: 100%;
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
    transition: border-color 0.2s;
  }
  .form__input:focus { border-color: var(--c-accent); }
  .form__input--textarea { resize: vertical; min-height: 150px; }

  .form__submit {
    align-self: flex-start;
    background: var(--c-accent);
    color: #fff;
    border: none;
    padding: 0.9rem 2.5rem;
    font-size: var(--text-sm);
    font-family: var(--font);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
  }
  .form__submit:hover { background: var(--c-accent-lt); }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-lg);
      padding-block: var(--sp-lg);
    }
  }
</style>
