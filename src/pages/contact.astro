---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RichText from "../components/RichText.tsx";
import { FONTS } from "../layouts/Layout.astro";
import { reader } from "../lib/keystatic-reader";

const contactPage = (await reader.singletons.contact_page.read({ resolveLinkedFiles: true })) ?? ({} as any);
const parametres = (await reader.singletons.parametres.read({ resolveLinkedFiles: true })) ?? ({} as any);

const rdvTexte = contactPage.rdv_texte || "Les visites sont sur rendez-vous uniquement, du lundi au vendredi, de 10h à 17h.";
const email    = parametres.email     || "contact@atipics.fr";
const tel      = parametres.telephone || "+33 6 00 00 00 00";
const adresse  = parametres.adresse   || [{ type: "paragraph", children: [{ text: "Village Atipics" }] }];

const form_tab_message = contactPage.form_tab_message || "Message";
const form_tab_mission = contactPage.form_tab_mission || "Confier une mission";
const form_titre_message = contactPage.form_titre_message || "ENVOYER UN MESSAGE";
const form_titre_mission = contactPage.form_titre_mission || "CONFIER UNE MISSION";

const info_rdv_label = contactPage.info_rdv_label || "PRENDRE RENDEZ-VOUS";
const info_email_label = contactPage.info_email_label || "EMAIL";
const info_tel_label = contactPage.info_tel_label || "TÉLÉPHONE";
const info_adresse_label = contactPage.info_adresse_label || "NOUS TROUVER";
const info_bouton_label = contactPage.info_bouton_label || "VISITER LE VILLAGE";

const SIZE_MAP: Record<string, string> = {
  inherit: '',
  xs: '0.75rem',
  sm: '0.875rem',
  base: '1rem',
  md: '1.125rem',
  lg: '1.25rem',
  xl: '1.5rem',
  '2xl': '2rem',
  '3xl': '2.5rem',
  '4xl': '3rem',
  '5xl': '4rem',
  '6xl': '5rem',
};

const WIDTH_MAP: Record<string, string> = {
  inherit: '',
  narrow: '32ch',
  medium: '46ch',
  wide: '64ch',
  xwide: '80ch',
  full: 'none',
};

const LINE_HEIGHT_MAP: Record<string, string> = {
  inherit: '',
  tight: '1.1',
  snug: '1.3',
  normal: '1.5',
  relaxed: '1.8',
  loose: '2.1',
  xloose: '2.4',
};

function elementStyle(data: any, prefix: string, defaultColor: string, defaultWeight = '400') {
  const fontKey = data[`${prefix}_font`];
  const fontRes = fontKey && fontKey !== 'inherit' && FONTS[fontKey] ? FONTS[fontKey] : null;
  const styleVal = data[`${prefix}_style`] || 'normal';
  const weightVal = data[`${prefix}_weight`];
  const size = SIZE_MAP[data[`${prefix}_size`]] || '';
  const color = data[`${prefix}_color`] || defaultColor;
  const align = data[`${prefix}_align`];
  const width = WIDTH_MAP[data[`${prefix}_width`]] || '';
  const lineHeight = LINE_HEIGHT_MAP[data[`${prefix}_line_height`]] || '';
  const obj: Record<string, string> = {
    color,
    fontWeight: weightVal && weightVal !== 'inherit' ? weightVal : (styleVal === 'bold' ? '700' : defaultWeight),
    fontStyle: styleVal === 'italic' ? 'italic' : 'normal',
  };
  if (fontRes) obj.fontFamily = fontRes.family;
  if (size) obj.fontSize = size;
  if (align && align !== 'inherit') obj.textAlign = align;
  if (width) obj.maxWidth = width;
  if (lineHeight) obj.lineHeight = lineHeight;
  const cssText = `color:${obj.color};font-weight:${obj.fontWeight};font-style:${obj.fontStyle};${obj.fontFamily ? `font-family:${obj.fontFamily};` : ''}${obj.fontSize ? `font-size:${obj.fontSize};` : ''}${obj.textAlign ? `text-align:${obj.textAlign};` : ''}${obj.maxWidth ? `max-width:${obj.maxWidth};` : ''}${obj.lineHeight ? `line-height:${obj.lineHeight};` : ''}`;
  return { obj, cssText, fontUrl: fontRes ? fontRes.url : null };
}

const defaultColor = contactPage.text_color || '#1A1A18';
const pageFontKey = contactPage.font && contactPage.font !== 'inherit' && FONTS[contactPage.font] ? contactPage.font : null;
const pageFont = pageFontKey ? FONTS[pageFontKey].family : null;
const pageFontUrl = pageFontKey ? FONTS[pageFontKey].url : null;

const tabMessageStyle = elementStyle(contactPage, 'tab_message', defaultColor);
const tabMissionStyle = elementStyle(contactPage, 'tab_mission', defaultColor);
const titreMessageStyle = elementStyle(contactPage, 'titre_message', defaultColor, '700');
const titreMissionStyle = elementStyle(contactPage, 'titre_mission', defaultColor, '700');
const rdvLabelStyle = elementStyle(contactPage, 'rdv_label', defaultColor, '700');
const rdvTexteStyle = elementStyle(contactPage, 'rdv_texte', defaultColor);
const emailLabelStyle = elementStyle(contactPage, 'email_label', defaultColor, '700');
const telLabelStyle = elementStyle(contactPage, 'tel_label', defaultColor, '700');
const adresseLabelStyle = elementStyle(contactPage, 'adresse_label', defaultColor, '700');
const boutonLabelStyle = elementStyle(contactPage, 'bouton_label', defaultColor, '600');

const contactFontUrls = [
  pageFontUrl,
  tabMessageStyle.fontUrl,
  tabMissionStyle.fontUrl,
  titreMessageStyle.fontUrl,
  titreMissionStyle.fontUrl,
  rdvLabelStyle.fontUrl,
  rdvTexteStyle.fontUrl,
  emailLabelStyle.fontUrl,
  telLabelStyle.fontUrl,
  adresseLabelStyle.fontUrl,
  boutonLabelStyle.fontUrl,
].filter((v, i, arr) => v && arr.indexOf(v) === i) as string[];
---

<Layout title={`Contact — ${parametres.nom_site}`} description="Contactez l'Agence Atipics">
  <Header />
  <main style="padding-top: var(--nav-h);">

    <section class="contact-section" style={pageFont ? { fontFamily: pageFont } : undefined}>
      {contactFontUrls.map((url) => <link rel="stylesheet" href={url} />)}
      <div class="container contact-grid">

        <!-- ── Colonne gauche : formulaire ── -->
        <div class="col-form">

          <!-- Titre + switch -->
          <div class="form-header">
            <div class="label-row">
              <span class="stamp" id="form-stamp" style={titreMessageStyle.obj} data-style-message={titreMessageStyle.cssText} data-style-mission={titreMissionStyle.cssText}>{form_titre_message}</span>
              <div class="rule"></div>
            </div>
            <div class="form-tabs" role="group" aria-label="Type de contact" data-label-message={form_titre_message} data-label-mission={form_titre_mission}>
              <button class="tab tab--active" data-tab="message" style={tabMessageStyle.obj}>{form_tab_message}</button>
              <span class="tab-sep" aria-hidden="true">/</span>
              <button class="tab" data-tab="mission" style={tabMissionStyle.obj}>{form_tab_mission}</button>
            </div>
          </div>

          <!-- Formulaire — Message général -->
          <form class="cform" id="form-message" name="contact-message" method="POST">
            <div class="cform__group">
              <label class="cform__label" for="msg-nom">NOM</label>
              <input class="cform__input" type="text" id="msg-nom" name="nom" required autocomplete="name" />
            </div>
            <div class="cform__group">
              <label class="cform__label" for="msg-email">EMAIL</label>
              <input class="cform__input" type="email" id="msg-email" name="email" required autocomplete="email" />
            </div>
            <div class="cform__group">
              <label class="cform__label" for="msg-message">MESSAGE</label>
              <textarea class="cform__input cform__textarea" id="msg-message" name="message" rows="6" required></textarea>
            </div>
            <label class="cform__check">
              <input class="cform__check-input" type="checkbox" name="newsletter" />
              <span class="cform__check-box" aria-hidden="true"></span>
              <span class="cform__check-label">J'accepte de recevoir la newsletter Atipics</span>
            </label>
            <button type="submit" class="cform__submit">
              ENVOYER LE MESSAGE <span class="cform__arrow" aria-hidden="true">→</span>
            </button>
          </form>

          <!-- Formulaire — Confier une mission -->
          <form class="cform cform--hidden" id="form-mission" name="contact-mission" method="POST">
            <div class="cform__row">
              <div class="cform__group">
                <label class="cform__label" for="ms-nom">NOM</label>
                <input class="cform__input" type="text" id="ms-nom" name="nom" required autocomplete="name" />
              </div>
              <div class="cform__group">
                <label class="cform__label" for="ms-societe">SOCIÉTÉ</label>
                <input class="cform__input" type="text" id="ms-societe" name="societe" autocomplete="organization" />
              </div>
            </div>
            <div class="cform__row">
              <div class="cform__group">
                <label class="cform__label" for="ms-email">EMAIL</label>
                <input class="cform__input" type="email" id="ms-email" name="email" required autocomplete="email" />
              </div>
              <div class="cform__group">
                <label class="cform__label" for="ms-tel">TÉLÉPHONE</label>
                <input class="cform__input" type="tel" id="ms-tel" name="telephone" autocomplete="tel" />
              </div>
            </div>
            <div class="cform__row">
              <div class="cform__group">
                <label class="cform__label" for="ms-expertise">DOMAINE D'EXPERTISE</label>
                <select class="cform__input cform__select" id="ms-expertise" name="expertise">
                  <option value="">Sélectionner…</option>
                  <option>Sourcing & chinage</option>
                  <option>Scénographie & décoration</option>
                  <option>Restauration & artisanat</option>
                  <option>Logistique & transport</option>
                  <option>Conseil & curation</option>
                  <option>Autre</option>
                </select>
              </div>
              <div class="cform__group">
                <label class="cform__label" for="ms-budget">BUDGET ESTIMÉ</label>
                <select class="cform__input cform__select" id="ms-budget" name="budget">
                  <option value="">Sélectionner…</option>
                  <option>Moins de 5 000 €</option>
                  <option>5 000 – 15 000 €</option>
                  <option>15 000 – 50 000 €</option>
                  <option>Plus de 50 000 €</option>
                  <option>À définir</option>
                </select>
              </div>
            </div>
            <div class="cform__group">
              <label class="cform__label" for="ms-mission">DESCRIPTION DE LA MISSION</label>
              <textarea class="cform__input cform__textarea" id="ms-mission" name="mission" rows="5" required></textarea>
            </div>
            <label class="cform__check">
              <input class="cform__check-input" type="checkbox" name="newsletter" />
              <span class="cform__check-box" aria-hidden="true"></span>
              <span class="cform__check-label">J'accepte de recevoir la newsletter Atipics</span>
            </label>
            <button type="submit" class="cform__submit">
              ENVOYER LA DEMANDE <span class="cform__arrow" aria-hidden="true">→</span>
            </button>
          </form>

        </div>

        <!-- ── Colonne droite : infos ── -->
        <div class="col-info">

          <div class="info-block">
            <p class="info-label" style={rdvLabelStyle.obj}>{info_rdv_label}</p>
            <RichText document={rdvTexte} className="info-text" style={rdvTexteStyle.obj} />
          </div>

          <div class="info-block">
            <p class="info-label" style={emailLabelStyle.obj}>{info_email_label}</p>
            <a href={`mailto:${email}`} class="info-link">{email}</a>
          </div>

          <div class="info-block">
            <p class="info-label" style={telLabelStyle.obj}>{info_tel_label}</p>
            <a href={`tel:${tel.replace(/\s/g, "")}`} class="info-link">{tel}</a>
          </div>

          <div class="info-block">
            <p class="info-label" style={adresseLabelStyle.obj}>{info_adresse_label}</p>
            <RichText document={adresse} className="info-text" />
          </div>

          <a href="/village" class="info-btn" style={boutonLabelStyle.obj}>
            {info_bouton_label} <span aria-hidden="true">→</span>
          </a>

        </div>

      </div>
    </section>

  </main>
  <Footer fixed />
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".tab");
  const formTabsContainer = document.querySelector(".form-tabs") as HTMLElement;
  const formMessage = document.getElementById("form-message");
  const formMission = document.getElementById("form-mission");
  const stamp = document.getElementById("form-stamp");

  const labels: Record<string, string> = {
    message: formTabsContainer?.dataset.labelMessage ?? "ENVOYER UN MESSAGE",
    mission: formTabsContainer?.dataset.labelMission ?? "CONFIER UNE MISSION",
  };
  const stampStyles: Record<string, string> = {
    message: stamp?.dataset.styleMessage ?? "",
    mission: stamp?.dataset.styleMission ?? "",
  };

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const target = tab.dataset.tab ?? "message";
      tabs.forEach((t) => {
        t.classList.toggle("tab--active", t.dataset.tab === target);
      });
      formMessage?.classList.toggle("cform--hidden", target !== "message");
      formMission?.classList.toggle("cform--hidden", target !== "mission");
      if (stamp) {
        stamp.textContent = labels[target] ?? "";
        stamp.style.cssText = stampStyles[target] ?? "";
      }
    });
  });
</script>

<style>
  /* ─── Layout ─── */
  .contact-section {
    padding-block: var(--sp-lg) var(--sp-xl);
    min-height: calc(100vh - var(--nav-h));
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-xl);
    align-items: start;
  }

  /* ─── Stamp + rule ─── */
  .label-row {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    margin-bottom: var(--sp-sm);
  }
  .stamp {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .rule { flex: 1; height: 1px; background: var(--c-border); }

  /* ─── Tab switch ─── */
  .form-header { margin-bottom: var(--sp-md); }

  .form-tabs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .tab {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font);
    font-size: var(--text-xs);
    color: var(--c-muted);
    letter-spacing: 0.04em;
    padding: 0;
    transition: color 0.2s;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .tab:hover { color: var(--c-text); }
  .tab--active {
    color: var(--c-text);
    border-bottom-color: var(--c-text);
  }
  .tab-sep { font-size: var(--text-xs); color: var(--c-border); }

  /* ─── Formulaire ─── */
  .cform {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }
  .cform--hidden { display: none; }

  .cform__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-sm);
  }

  .cform__group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .cform__label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--c-muted);
  }

  .cform__input {
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    padding: 0.6rem 0.75rem;
    font-size: var(--text-xs);
    font-family: var(--font);
    color: var(--c-text);
    width: 100%;
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
    transition: border-color 0.2s;
  }
  .cform__input:focus { border-color: var(--c-text); }
  .cform__textarea { resize: vertical; min-height: 130px; }
  .cform__select { cursor: pointer; }

  /* ─── Checkbox newsletter ─── */
  .cform__check {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    margin-top: 0.1rem;
  }
  .cform__check-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .cform__check-box {
    width: 14px;
    height: 14px;
    border: 1px solid var(--c-border);
    flex-shrink: 0;
    position: relative;
    transition: background 0.15s, border-color 0.15s;
  }
  .cform__check-input:checked + .cform__check-box {
    background: var(--c-text);
    border-color: var(--c-text);
  }
  .cform__check-input:checked + .cform__check-box::after {
    content: '';
    position: absolute;
    left: 3px;
    top: 1px;
    width: 5px;
    height: 8px;
    border: 1.5px solid var(--c-bg);
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }
  .cform__check-label {
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--c-muted);
  }

  /* ─── Submit ─── */
  .cform__submit {
    align-self: flex-start;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--c-text);
    background: none;
    padding: 0.65rem 1.4rem;
    font-size: 0.7rem;
    font-family: var(--font);
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--c-text);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    margin-top: 0.25rem;
  }
  .cform__submit:hover {
    background: var(--c-text);
    color: var(--c-bg);
  }
  .cform__arrow { font-size: 0.85rem; transition: transform 0.2s; }
  .cform__submit:hover .cform__arrow { transform: translateX(3px); }

  /* ─── Colonne info ─── */
  .col-info {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
    padding-top: calc(var(--sp-sm) + 1.5rem); /* aligne avec le début du form */
  }

  .info-block { display: flex; flex-direction: column; gap: 0.4rem; }

  .info-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--c-text);
  }

  .info-text {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: 1.8;
  }

  .info-link {
    font-size: var(--text-xs);
    color: var(--c-muted);
    border-bottom: 1px solid var(--c-border);
    display: inline-block;
    transition: color 0.2s, border-color 0.2s;
  }
  .info-link:hover { color: var(--c-text); border-color: var(--c-text); }

  .info-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--c-text);
    padding: 0.65rem 1.4rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--c-text);
    align-self: flex-start;
    transition: background 0.2s, color 0.2s;
    margin-top: var(--sp-xs);
  }
  .info-btn:hover { background: var(--c-text); color: var(--c-bg); }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: var(--sp-lg); }
    .col-info { padding-top: 0; }
  }
  @media (max-width: 600px) {
    .cform__row { grid-template-columns: 1fr; }
  }
</style>
