---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import bandeauData from "../content/pages/agence-bandeau.json";
import sectionsData from "../content/pages/agence-sections.json";
import parametres from "../content/parametres/index.json";
import RichText from "../components/RichText.tsx";
import { FONTS } from "../layouts/Layout.astro";
import { optimizePath } from "../lib/image";

const bandeauAgence = bandeauData.bandeau_image ? optimizePath(`/images/${bandeauData.bandeau_image}`) : optimizePath("/images/projet1.jpg");
const bandeauLabel = bandeauData.bandeau_label || "L'Agence";
const bandeauTitre = bandeauData.bandeau_titre || "Atipics";
const intro = bandeauData.intro;
const hasIntro = intro && Array.isArray(intro) && intro.some((node: any) => node?.children?.some((child: any) => (child.text || '').trim() !== ''));

const styleMap: Record<string, string> = {
  normal: 'normal',
  bold: 'bold',
  italic: 'italic',
};

// Bandeau styles
const bandeauFontKey = bandeauData.font && bandeauData.font !== 'inherit' && FONTS[bandeauData.font] ? bandeauData.font : null;
const bandeauFont = bandeauFontKey ? FONTS[bandeauFontKey].family : null;
const bandeauFontUrl = bandeauFontKey ? FONTS[bandeauFontKey].url : null;
const bandeauColor = bandeauData.text_color || '#ffffff';
const bandeauLabelStyle = styleMap[bandeauData.label_style] || 'bold';
const bandeauTitreStyle = styleMap[bandeauData.titre_style] || 'normal';
const bandeauIntroStyle = styleMap[bandeauData.intro_style] || 'normal';

const sections = (sectionsData.sections || []).map((s: any, i: number) => {
  const fontKey = s.font && s.font !== 'inherit' && FONTS[s.font] ? s.font : null;
  return {
    slug: s.title ? s.title.toLowerCase().replace(/[^a-z0-9]+/g, '-') : `section-${i}`,
    label: s.label || '',
    titre: s.title || '',
    content: s.content || [],
    reverse: i % 2 === 1,
    fallbackImg: i % 2 === 0 ? "/images/projet2.webp" : "/images/projet3.jpg",
    images: (s.images || []).map((src: string) => optimizePath(src.startsWith('/images/') ? src : `/images/${src}`)),
    font: fontKey ? FONTS[fontKey].family : null,
    fontUrl: fontKey ? FONTS[fontKey].url : null,
    color: s.text_color || '#1A1A18',
    labelStyle: styleMap[s.label_style] || 'bold',
    titreStyle: styleMap[s.title_style] || 'normal',
    textStyle: styleMap[s.text_style] || 'normal',
  };
});
---

<Layout title={`Agence Atipics — ${parametres.nom_site}`} description="Manifeste et réseaux de l'Agence Atipics">
  {bandeauFontUrl && <link rel="stylesheet" href={bandeauFontUrl} />}
  <Header />
  <main style="padding-top: var(--nav-h);">

    <!-- Bandeau pleine largeur -->
    <section class="bandeau" style={`${bandeauFont ? `font-family: ${bandeauFont};` : ''}--bandeau-color:${bandeauColor};--bandeau-label-weight:${bandeauLabelStyle === 'bold' ? '700' : '400'};--bandeau-label-style:${bandeauLabelStyle === 'italic' ? 'italic' : 'normal'};--bandeau-titre-weight:${bandeauTitreStyle === 'bold' ? '700' : '200'};--bandeau-titre-style:${bandeauTitreStyle === 'italic' ? 'italic' : 'normal'}`}>
      <img src={bandeauAgence} alt="Atipics" class="bandeau__img" decoding="async" />
      <div class="bandeau__overlay">
        <div class="container bandeau__text">
          <p class="bandeau__label">{bandeauLabel}</p>
          <h1 class="bandeau__title">{bandeauTitre}</h1>
        </div>
      </div>
    </section>

    {hasIntro && (
      <section class="intro-section" style={`--intro-weight:${bandeauIntroStyle === 'bold' ? '600' : '300'};--intro-style:${bandeauIntroStyle === 'italic' ? 'italic' : 'normal'}`}>
        <div class="container">
          <RichText document={intro} className="intro-desc" />
        </div>
      </section>
    )}

    <!-- Sections dynamiques -->
    {sections.map((s) => {
      const imgs = s.images ?? [];
      const content = s.content;
      return (
        <section class:list={["split-block", { "split-block--alt": s.reverse }]} id={s.slug} style={`${s.font ? `font-family: ${s.font};` : ''}--section-color:${s.color};--section-label-weight:${s.labelStyle === 'bold' ? '700' : '400'};--section-label-style:${s.labelStyle === 'italic' ? 'italic' : 'normal'};--section-titre-weight:${s.titreStyle === 'bold' ? '700' : '200'};--section-titre-style:${s.titreStyle === 'italic' ? 'italic' : 'normal'};--section-text-weight:${s.textStyle === 'bold' ? '600' : '400'};--section-text-style:${s.textStyle === 'italic' ? 'italic' : 'normal'}`}>
          {s.fontUrl && <link rel="stylesheet" href={s.fontUrl} />}
          <div class="container">
            <div class="label-row">
              <span class="stamp">{s.label}</span>
              <div class="rule"></div>
            </div>
            <div class:list={["split-grid", { "split-grid--reverse": s.reverse }]}>
              {s.reverse && (
                <div class="split-img-col">
                  {imgs.length > 0 ? (
                    <div class="acarousel" data-acarousel>
                      <div class="acarousel__track">
                        {imgs.map((src, j) => (
                          <div class:list={["acarousel__slide", { "is-active": j === 0 }]} aria-hidden={j !== 0}>
                            <img src={src} alt={`${s.label} ${j + 1}`} class="split-img" loading="lazy" />
                          </div>
                        ))}
                      </div>
                      {imgs.length > 1 && (
                        <>
                          <button class="acarousel__btn acarousel__btn--prev" aria-label="Précédent"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                          <button class="acarousel__btn acarousel__btn--next" aria-label="Suivant"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                          <div class="acarousel__counter" data-acounter></div>
                        </>
                      )}
                    </div>
                  ) : (
                    <img src={optimizePath("/images/projet3.jpg")} alt={s.titre} class="split-img" loading="lazy" />
                  )}
                </div>
              )}
              <div class="split-text">
                <h2 class="split-title" set:html={s.titre} />
                {content && <RichText document={content} className="split-p" />}
              </div>
              {!s.reverse && (
                <div class="split-img-col">
                  {imgs.length > 0 ? (
                    <div class="acarousel" data-acarousel>
                      <div class="acarousel__track">
                        {imgs.map((src, j) => (
                          <div class:list={["acarousel__slide", { "is-active": j === 0 }]} aria-hidden={j !== 0}>
                            <img src={src} alt={`${s.label} ${j + 1}`} class="split-img" loading="lazy" />
                          </div>
                        ))}
                      </div>
                      {imgs.length > 1 && (
                        <>
                          <button class="acarousel__btn acarousel__btn--prev" aria-label="Précédent"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                          <button class="acarousel__btn acarousel__btn--next" aria-label="Suivant"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                          <div class="acarousel__counter" data-acounter></div>
                        </>
                      )}
                    </div>
                  ) : (
                    <img src={optimizePath("/images/projet2.webp")} alt={s.titre} class="split-img" loading="lazy" />
                  )}
                </div>
              )}
            </div>
          </div>
        </section>
      );
    })}

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Bandeau ─── */
  .bandeau {
    position: relative;
    width: 100%;
    height: 58vh;
    overflow: hidden;
  }
  .bandeau__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  .bandeau__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.52) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
    display: flex;
    align-items: flex-end;
  }
  .bandeau__text {
    padding-bottom: var(--sp-xl);
    color: var(--bandeau-color, #fff);
  }
  .bandeau__label {
    font-size: 0.68rem;
    font-weight: var(--bandeau-label-weight, 700);
    font-style: var(--bandeau-label-style, normal);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }
  .bandeau__title {
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: var(--bandeau-titre-weight, 200);
    font-style: var(--bandeau-titre-style, normal);
    letter-spacing: -0.03em;
    line-height: 0.92;
  }

  /* ─── Intro ─── */
  .intro-section {
    padding-block: var(--sp-xl);
    border-bottom: 1px solid var(--c-border);
  }
  .intro-desc {
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    font-weight: var(--intro-weight, 300);
    font-style: var(--intro-style, normal);
    color: var(--c-muted);
    line-height: 1.75;
    max-width: 64ch;
    letter-spacing: -0.01em;
  }
  :global(.intro-desc) {
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    font-weight: var(--intro-weight, 300);
    font-style: var(--intro-style, normal);
    color: var(--c-muted);
    line-height: 1.75;
    max-width: 64ch;
    letter-spacing: -0.01em;
  }

  /* ─── Label row ─── */
  .label-row {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    margin-bottom: var(--sp-lg);
  }
  .stamp {
    font-size: 0.68rem;
    font-weight: var(--section-label-weight, 700);
    font-style: var(--section-label-style, normal);
    letter-spacing: 0.18em;
    color: var(--section-color, var(--c-muted));
    white-space: nowrap;
    flex-shrink: 0;
  }
  .rule { flex: 1; height: 1px; background: var(--c-border); }

  .text-link {
    border-bottom: 1px solid var(--c-border);
    transition: border-color 0.2s;
  }
  .text-link:hover { border-bottom-color: var(--c-text); }

  /* ─── Split blocks ─── */
  .split-block {
    padding-block: calc(var(--sp-xl) * 1.5);
    border-bottom: 1px solid var(--c-border);
  }
  .split-block--alt { background: var(--c-surface); }
  .split-block:last-child { border-bottom: none; }

  .split-grid {
    display: grid;
    grid-template-columns: 1fr 52%;
    gap: var(--sp-xl);
    align-items: center;
  }
  .split-grid--reverse {
    grid-template-columns: 52% 1fr;
  }

  .split-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .split-title {
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    font-weight: var(--section-titre-weight, 200);
    font-style: var(--section-titre-style, normal);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: var(--sp-md);
    color: var(--section-color, inherit);
  }
  .split-p {
    font-size: var(--text-sm);
    font-weight: var(--section-text-weight, 400);
    font-style: var(--section-text-style, normal);
    color: var(--section-color, var(--c-muted));
    line-height: 1.9;
    margin-bottom: 1.5rem;
    max-width: 48ch;
  }
  .split-p:last-child { margin-bottom: 0; }
  :global(.split-p) {
    font-size: var(--text-sm);
    font-weight: var(--section-text-weight, 400);
    font-style: var(--section-text-style, normal);
    color: var(--section-color, var(--c-muted));
    line-height: 1.9;
    margin-bottom: 1.5rem;
    max-width: 48ch;
  }
  :global(.split-p:last-child) { margin-bottom: 0; }

  /* ─── Agence carousel ─── */
  .acarousel {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .acarousel__track { width: 100%; height: 100%; }
  .acarousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  .acarousel__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .acarousel__slide .split-img {
    aspect-ratio: unset;
    height: 100%;
    width: 100%;
    object-fit: cover;
  }
  .acarousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    color: #fff;
    width: 2.2rem;
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.25s, background 0.2s;
    backdrop-filter: blur(4px);
  }
  .acarousel:hover .acarousel__btn { opacity: 1; }
  .acarousel__btn:hover { background: rgba(255,255,255,0.22); }
  .acarousel__btn--prev { left: 0.5rem; }
  .acarousel__btn--next { right: 0.5rem; }
  .acarousel__counter {
    position: absolute;
    bottom: 0.5rem;
    right: 0.75rem;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.08em;
    z-index: 10;
  }

  @media (max-width: 900px) {
    .bandeau { height: 50vh; }
    .split-grid,
    .split-grid--reverse { grid-template-columns: 1fr; }
    .split-grid--reverse .split-img-col { order: -1; }
    .split-p { max-width: 100%; }
    .acarousel__btn { opacity: 1; }
  }
  @media (max-width: 600px) {
    .bandeau { height: 42vh; }
    .split-block { padding-block: var(--sp-xl); }
  }
</style>

<script>
  document.querySelectorAll('[data-acarousel]').forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll('.acarousel__slide'));
    const prev = carousel.querySelector('.acarousel__btn--prev');
    const next = carousel.querySelector('.acarousel__btn--next');
    const counter = carousel.querySelector('[data-acounter]');
    let cur = 0;
    function go(n: number) {
      slides[cur].classList.remove('is-active');
      slides[cur].setAttribute('aria-hidden', 'true');
      cur = ((n % slides.length) + slides.length) % slides.length;
      slides[cur].classList.add('is-active');
      slides[cur].setAttribute('aria-hidden', 'false');
      if (counter) counter.textContent = `${cur + 1} / ${slides.length}`;
    }
    if (counter && slides.length > 1) counter.textContent = `1 / ${slides.length}`;
    prev?.addEventListener('click', () => go(cur - 1));
    next?.addEventListener('click', () => go(cur + 1));
  });
</script>
