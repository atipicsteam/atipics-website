---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import cms from "../content/pages/agence.json";
import parametres from "../content/parametres/index.json";
import RichText from "../components/RichText.tsx";

const bandeauAgence = cms.bandeau_image ? `/images/${cms.bandeau_image}` : "/images/projet1.jpg";
const bandeauLabel = cms.bandeau_label || "L'Agence";
const bandeauTitre = cms.bandeau_titre || "Atipics";
const intro = cms.intro || "Ressourcerie éclectique et polyvalente — dix ans de savoir-faire au service de projets singuliers, pour particuliers, collectionneurs et professionnels.";

const agenceImages: Record<string, string[]> = {
  manifeste: cms.manifeste_images || [],
  reseaux: cms.reseaux_images || [],
};


const sections = [
  {
    slug: "manifeste",
    label: cms.manifeste_label || "MANIFESTE",
    titre: cms.manifeste_titre || "Une agence hors des sentiers battus",
    paragraphes: [
      cms.manifeste_p1 || "Atipics est née d'une conviction : chaque espace, chaque objet, chaque projet mérite une attention singulière. Nous cultivons l'art de la trouvaille, du détail inattendu, du savoir-faire transmis.",
      cms.manifeste_p2 || "Curateurs, logisticiens, scénographes — nous sommes avant tout des passionnés animés par la conviction que les objets ont une histoire, et que cette histoire mérite d'être racontée.",
      cms.manifeste_p3 || "Notre ancrage au Village Atipics, véritable hub de créativité et de compétences, nous permet d'offrir un écosystème complet, du sourcing à la mise en valeur finale.",
    ].filter(Boolean),
    reverse: false,
    fallbackImg: "/images/projet2.webp",
  },
  {
    slug: "reseaux",
    label: cms.reseaux_label || "RÉSEAUX",
    titre: cms.reseaux_titre || "Un réseau d'exception",
    paragraphes: [
      cms.reseaux_p1 || "Artisans, antiquaires, architectes, artistes — notre carnet d'adresses est le fruit de dix années de rencontres et de confiance mutuelle. Un réseau humain, construit sur la durée.",
      cms.reseaux_p2 || "Ébénistes, tapissiers, ferronniers, doreurs — des mains expertes qui perpétuent les savoir-faire. Un accès privilégié aux meilleures sources, en France et à l'international.",
      cms.reseaux_p3 || "Des collaborations croisées avec architectes et designers pour des projets qui mêlent structure, espace et objet. Une discrétion absolue pour accompagner les projets les plus sensibles.",
      cms.reseaux_p4 || `Pour toute demande, contactez-nous à <a href="mailto:${parametres.email}" class="text-link">${parametres.email}</a>.`,
    ].filter(Boolean),
    reverse: true,
    fallbackImg: "/images/projet3.jpg",
  },
];
---

<Layout title={`Agence Atipics — ${parametres.nom_site}`} description="Manifeste et réseaux de l'Agence Atipics">
  <Header />
  <main style="padding-top: var(--nav-h);">

    <!-- Bandeau pleine largeur -->
    <section class="bandeau">
      <img src={bandeauAgence} alt="Atipics" class="bandeau__img" />
      <div class="bandeau__overlay">
        <div class="container bandeau__text">
          <p class="bandeau__label">{bandeauLabel}</p>
          <h1 class="bandeau__title">{bandeauTitre}</h1>
        </div>
      </div>
    </section>

    <!-- Intro -->
    <section class="intro-section">
      <div class="container">
        <RichText document={intro} className="intro-desc" />
      </div>
    </section>

    <!-- Sections dynamiques -->
    {sections.map((s) => {
      const imgs = agenceImages[s.slug] ?? [];
      const paragraphes = s.paragraphes;
      return (
        <section class:list={["split-block", { "split-block--alt": s.reverse }]} id={s.slug}>
          <div class="container">
            <div class="label-row">
              <span class="stamp">{s.label}</span>
              <div class="rule"></div>
            </div>
            <div class:list={["split-grid", { "split-grid--reverse": s.reverse }]}>
              {s.reverse && (
                <div class="split-img-col">
                  {imgs.length > 0 ? (
                    <div class="acarousel" data-acarousel>
                      <div class="acarousel__track">
                        {imgs.map((src, j) => (
                          <div class:list={["acarousel__slide", { "is-active": j === 0 }]} aria-hidden={j !== 0}>
                            <img src={src} alt={`${s.label} ${j + 1}`} class="split-img" loading="lazy" />
                          </div>
                        ))}
                      </div>
                      {imgs.length > 1 && (
                        <>
                          <button class="acarousel__btn acarousel__btn--prev" aria-label="Précédent"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                          <button class="acarousel__btn acarousel__btn--next" aria-label="Suivant"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                          <div class="acarousel__counter" data-acounter></div>
                        </>
                      )}
                    </div>
                  ) : (
                    <img src="/images/projet3.jpg" alt={s.titre} class="split-img" loading="lazy" />
                  )}
                </div>
              )}
              <div class="split-text">
                <h2 class="split-title" set:html={s.titre} />
                {paragraphes.map((p) => (
                  <RichText document={p} className="split-p" />
                ))}
              </div>
              {!s.reverse && (
                <div class="split-img-col">
                  {imgs.length > 0 ? (
                    <div class="acarousel" data-acarousel>
                      <div class="acarousel__track">
                        {imgs.map((src, j) => (
                          <div class:list={["acarousel__slide", { "is-active": j === 0 }]} aria-hidden={j !== 0}>
                            <img src={src} alt={`${s.label} ${j + 1}`} class="split-img" loading="lazy" />
                          </div>
                        ))}
                      </div>
                      {imgs.length > 1 && (
                        <>
                          <button class="acarousel__btn acarousel__btn--prev" aria-label="Précédent"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                          <button class="acarousel__btn acarousel__btn--next" aria-label="Suivant"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                          <div class="acarousel__counter" data-acounter></div>
                        </>
                      )}
                    </div>
                  ) : (
                    <img src="/images/projet2.webp" alt={s.titre} class="split-img" loading="lazy" />
                  )}
                </div>
              )}
            </div>
          </div>
        </section>
      );
    })}

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Bandeau ─── */
  .bandeau {
    position: relative;
    width: 100%;
    height: 58vh;
    overflow: hidden;
  }
  .bandeau__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  .bandeau__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.52) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
    display: flex;
    align-items: flex-end;
  }
  .bandeau__text {
    padding-bottom: var(--sp-xl);
    color: #fff;
  }
  .bandeau__label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }
  .bandeau__title {
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    line-height: 0.92;
  }

  /* ─── Intro ─── */
  .intro-section {
    padding-block: var(--sp-xl);
    border-bottom: 1px solid var(--c-border);
  }
  .intro-desc {
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    font-weight: 300;
    color: var(--c-muted);
    line-height: 1.75;
    max-width: 64ch;
    letter-spacing: -0.01em;
  }

  /* ─── Label row ─── */
  .label-row {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    margin-bottom: var(--sp-lg);
  }
  .stamp {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .rule { flex: 1; height: 1px; background: var(--c-border); }

  .text-link {
    border-bottom: 1px solid var(--c-border);
    transition: border-color 0.2s;
  }
  .text-link:hover { border-bottom-color: var(--c-text); }

  /* ─── Split blocks ─── */
  .split-block {
    padding-block: calc(var(--sp-xl) * 1.5);
    border-bottom: 1px solid var(--c-border);
  }
  .split-block--alt { background: var(--c-surface); }
  .split-block:last-child { border-bottom: none; }

  .split-grid {
    display: grid;
    grid-template-columns: 1fr 52%;
    gap: var(--sp-xl);
    align-items: center;
  }
  .split-grid--reverse {
    grid-template-columns: 52% 1fr;
  }

  .split-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .split-title {
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    font-weight: 200;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: var(--sp-md);
  }
  .split-p {
    font-size: var(--text-sm);
    color: var(--c-muted);
    line-height: 1.9;
    margin-bottom: 1rem;
    max-width: 48ch;
  }
  .split-p:last-child { margin-bottom: 0; }

  /* ─── Agence carousel ─── */
  .acarousel {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .acarousel__track { width: 100%; height: 100%; }
  .acarousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  .acarousel__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  .acarousel__slide .split-img {
    aspect-ratio: unset;
    height: 100%;
    width: 100%;
    object-fit: cover;
  }
  .acarousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    color: #fff;
    width: 2.2rem;
    height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.25s, background 0.2s;
    backdrop-filter: blur(4px);
  }
  .acarousel:hover .acarousel__btn { opacity: 1; }
  .acarousel__btn:hover { background: rgba(255,255,255,0.22); }
  .acarousel__btn--prev { left: 0.5rem; }
  .acarousel__btn--next { right: 0.5rem; }
  .acarousel__counter {
    position: absolute;
    bottom: 0.5rem;
    right: 0.75rem;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.08em;
    z-index: 10;
  }

  @media (max-width: 900px) {
    .bandeau { height: 50vh; }
    .split-grid,
    .split-grid--reverse { grid-template-columns: 1fr; }
    .split-grid--reverse .split-img-col { order: -1; }
    .split-p { max-width: 100%; }
    .acarousel__btn { opacity: 1; }
  }
  @media (max-width: 600px) {
    .bandeau { height: 42vh; }
    .split-block { padding-block: var(--sp-xl); }
  }
</style>

<script>
  document.querySelectorAll('[data-acarousel]').forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll('.acarousel__slide'));
    const prev = carousel.querySelector('.acarousel__btn--prev');
    const next = carousel.querySelector('.acarousel__btn--next');
    const counter = carousel.querySelector('[data-acounter]');
    let cur = 0;
    function go(n: number) {
      slides[cur].classList.remove('is-active');
      slides[cur].setAttribute('aria-hidden', 'true');
      cur = ((n % slides.length) + slides.length) % slides.length;
      slides[cur].classList.add('is-active');
      slides[cur].setAttribute('aria-hidden', 'false');
      if (counter) counter.textContent = `${cur + 1} / ${slides.length}`;
    }
    if (counter && slides.length > 1) counter.textContent = `1 / ${slides.length}`;
    prev?.addEventListener('click', () => go(cur - 1));
    next?.addEventListener('click', () => go(cur + 1));
  });
</script>
