---
interface Props {
  title?: string;
  description?: string;
}
const { title = "ATIPICS", description = "Ressourcerie éclectique et polyvalente" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════════════
     VARIABLES — modifiez ici pour changer les couleurs
  ═══════════════════════════════════════════════════ */
  :root {
    /* --- Couleurs --- */
    --c-bg:        #FAFAF8;
    --c-text:      #1A1A18;
    --c-accent:    #2E4D3F;
    --c-accent-lt: #4A7A65;
    --c-muted:     #888884;
    --c-border:    #E4E1DA;
    --c-surface:   #F0EDE7;

    /* --- Typographie --- */
    --font:       'Helvetica Neue', Helvetica, Arial, sans-serif;
    --font-serif: Georgia, 'Times New Roman', serif;

    --text-xs:   0.875rem;
    --text-sm:   1rem;
    --text-base: 1.125rem;
    --text-lg:   1.375rem;
    --text-xl:   1.75rem;
    --text-2xl:  2.25rem;
    --text-3xl:  2.75rem;
    --text-4xl:  4rem;
    --text-hero: clamp(3.5rem, 10vw, 8.5rem);

    /* --- Espacement --- */
    --sp-xs: 0.5rem;
    --sp-sm: 1rem;
    --sp-md: 2rem;
    --sp-lg: 4rem;
    --sp-xl: 8rem;

    /* --- Layout --- */
    --max-w: 1200px;
    --nav-h:    4.5rem;
    --footer-h: 3.75rem;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    font-family: var(--font);
    background: var(--c-bg);
    color: var(--c-text);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body { min-height: 100vh; }
  img, video { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  ul, ol { list-style: none; }

  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: var(--sp-md);
  }

  .section {
    padding-block: var(--sp-xl);
  }

  .section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: var(--sp-sm);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: var(--sp-sm);
  }

  .section-intro {
    font-size: var(--text-lg);
    color: var(--c-muted);
    max-width: 60ch;
    line-height: 1.7;
  }

  .divider {
    width: 2.5rem;
    height: 2px;
    background: var(--c-accent);
    margin-block: var(--sp-md);
  }

  @media (max-width: 768px) {
    .section { padding-block: var(--sp-lg); }
    .section-title { font-size: var(--text-2xl); }
    .container { padding-inline: var(--sp-sm); }
  }
</style>
