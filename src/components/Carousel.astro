---
import carouselData from "../content/carousel/index.json";
import { FONTS } from "../layouts/Layout.astro";
import { optimizePath } from "../lib/image";

const slides = carouselData.slides;
const interval = 5000;

const carouselFontKey = carouselData.font && carouselData.font !== 'inherit' && FONTS[carouselData.font]
  ? carouselData.font
  : null;
const carouselFont = carouselFontKey ? FONTS[carouselFontKey].family : null;
const carouselFontUrl = carouselFontKey ? FONTS[carouselFontKey].url : null;
const carouselColor = carouselData.text_color || '#ffffff';

const styleMap: Record<string, string> = {
  normal: 'normal',
  bold: 'bold',
  italic: 'italic',
};
const titleStyle = styleMap[carouselData.title_style] || 'normal';
const categoryStyle = styleMap[carouselData.category_style] || 'normal';
---

{carouselFontUrl && <link rel="stylesheet" href={carouselFontUrl} />}

<section class="carousel" aria-label="Projets en vedette" style={`${carouselFont ? `font-family: ${carouselFont};` : ''}--carousel-color:${carouselColor};--carousel-title-weight:${titleStyle === 'bold' ? '700' : '300'};--carousel-title-style:${titleStyle === 'italic' ? 'italic' : 'normal'};--carousel-category-weight:${categoryStyle === 'bold' ? '700' : '400'};--carousel-category-style:${categoryStyle === 'italic' ? 'italic' : 'normal'}`}>
  <div class="carousel__track">
    {slides.map((slide, i) => (
      <div
        class:list={["carousel__slide", { "is-active": i === 0 }]}
        aria-hidden={i !== 0}
      >
        <img src={optimizePath(slide.image.startsWith('/images/') ? slide.image : `/images/${slide.image}`)} alt={slide.title} class="carousel__img" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
        <div class="carousel__overlay"></div>
        <div class="carousel__content">
          <span class="carousel__category">{slide.category} — {slide.year}</span>
          <h2 class="carousel__title">{slide.title}</h2>
        </div>
      </div>
    ))}
  </div>

  <button class="carousel__arrow carousel__arrow--prev" aria-label="Projet précédent">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <button class="carousel__arrow carousel__arrow--next" aria-label="Projet suivant">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="carousel__dots">
    {slides.map((_, i) => (
      <button
        class:list={["carousel__dot", { "is-active": i === 0 }]}
        aria-label={`Projet ${i + 1}`}
      />
    ))}
  </div>

  <div class="carousel__progress">
    <div class="carousel__progress-bar"></div>
  </div>
</section>

<script is:inline define:vars={{ interval }}>
  (function () {
    const slides = document.querySelectorAll(".carousel__slide");
    const dots = document.querySelectorAll(".carousel__dot");
    const bar = document.querySelector(".carousel__progress-bar");
    const prevBtn = document.querySelector(".carousel__arrow--prev");
    const nextBtn = document.querySelector(".carousel__arrow--next");
    let current = 0;
    let timer;

    function goTo(n) {
      slides[current].classList.remove("is-active");
      slides[current].setAttribute("aria-hidden", "true");
      dots[current]?.classList.remove("is-active");
      current = ((n % slides.length) + slides.length) % slides.length;
      slides[current].classList.add("is-active");
      slides[current].setAttribute("aria-hidden", "false");
      dots[current]?.classList.add("is-active");
      resetBar();
    }

    function resetBar() {
      if (!bar) return;
      bar.style.transition = "none";
      bar.style.width = "0%";
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          bar.style.transition = `width ${interval}ms linear`;
          bar.style.width = "100%";
        });
      });
    }

    function start() {
      timer = setInterval(() => goTo(current + 1), interval);
      resetBar();
    }
    function stop() {
      clearInterval(timer);
      if (bar) bar.style.transition = "none";
    }

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => { stop(); goTo(i); start(); });
    });

    prevBtn?.addEventListener("click", () => { stop(); goTo(current - 1); start(); });
    nextBtn?.addEventListener("click", () => { stop(); goTo(current + 1); start(); });

    const carousel = document.querySelector(".carousel");
    carousel?.addEventListener("mouseenter", stop);
    carousel?.addEventListener("mouseleave", start);

    start();
  })();
</script>

<style>
  .carousel {
    position: relative;
    width: 100%;
    height: calc(100vh - var(--nav-h) - var(--footer-h) - var(--social-bar-h));
    height: calc(100dvh - var(--nav-h) - var(--footer-h) - var(--social-bar-h));
    overflow: hidden;
    background: var(--c-bg);
  }

  .carousel__track { width: 100%; height: 100%; }

  .carousel__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease;
    pointer-events: none;
  }
  .carousel__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .carousel__img {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--sp-md);
    right: var(--sp-md);
    width: calc(100% - 2 * var(--sp-md));
    height: 100%;
    object-fit: cover;
  }

  .carousel__overlay {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--sp-md);
    right: var(--sp-md);
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);
  }

  .carousel__content {
    position: absolute;
    bottom: var(--sp-xl);
    left: calc(var(--sp-xl) + var(--sp-md));
    color: var(--carousel-color, #fff);
    z-index: 1;
  }

  .carousel__category {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--carousel-category-weight, 400);
    font-style: var(--carousel-category-style, normal);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.65;
    margin-bottom: var(--sp-xs);
  }

  .carousel__title {
    font-size: clamp(2.5rem, 7vw, 7rem);
    font-weight: var(--carousel-title-weight, 200);
    font-style: var(--carousel-title-style, normal);
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  /* ─── Arrows ─── */
  .carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    color: #fff;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.25s, background 0.2s;
    backdrop-filter: blur(4px);
  }
  .carousel:hover .carousel__arrow { opacity: 1; }
  .carousel__arrow:hover { background: rgba(255,255,255,0.22); }
  .carousel__arrow--prev { left: calc(var(--sp-md) + 0.75rem); }
  .carousel__arrow--next { right: calc(var(--sp-md) + 0.75rem); }

  /* ─── Dots ─── */
  .carousel__dots {
    position: absolute;
    bottom: var(--sp-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }

  .carousel__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .carousel__dot.is-active {
    background: #fff;
    transform: scale(1.4);
  }

  /* ─── Progress bar ─── */
  .carousel__progress {
    position: absolute;
    bottom: 0;
    left: var(--sp-md);
    right: var(--sp-md);
    height: 2px;
    background: rgba(255,255,255,0.15);
    z-index: 10;
  }

  .carousel__progress-bar {
    height: 100%;
    width: 0%;
    background: rgba(255,255,255,0.7);
  }

  @media (max-width: 768px) {
    .carousel__content {
      bottom: var(--sp-lg);
      left: var(--sp-sm);
    }
    .carousel__img {
      left: var(--sp-sm);
      right: var(--sp-sm);
      width: calc(100% - 2 * var(--sp-sm));
    }
    .carousel__arrow { opacity: 1; }
    .carousel__arrow--prev { left: calc(var(--sp-sm) + 0.25rem); }
    .carousel__arrow--next { right: calc(var(--sp-sm) + 0.25rem); }
  }
</style>
