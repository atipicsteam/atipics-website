---
import { site } from "../site.config";
const { reseau } = site;
---

<section class="section reseau" id="reseau">
  <div class="container">
    <div class="reseau__header">
      <div>
        <p class="section-label">Collectif</p>
        <h2 class="section-title">{reseau.title}</h2>
        <div class="divider"></div>
        <p class="section-intro">{reseau.description}</p>
      </div>
      <div class="reseau__badge">
        <span class="reseau__badge-number">{reseau.badge}</span>
        <span class="reseau__badge-label">d'existence</span>
      </div>
    </div>

    <div class="reseau__stats">
      {reseau.stats.map((stat) => (
        <div class="stat">
          <span class="stat__value">{stat.value}</span>
          <span class="stat__label">{stat.label}</span>
        </div>
      ))}
    </div>

    <div class="reseau__metiers">
      <p class="section-label" style="margin-bottom: var(--sp-sm);">Nos métiers</p>
      <ul class="metiers-list">
        {reseau.metiers.map((m) => (
          <li class="metiers-list__item">{m}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .reseau {
    background: var(--c-text);
    color: var(--c-bg);
  }

  .reseau .section-label { color: var(--c-accent-lt); }
  .reseau .section-title { color: #fff; }
  .reseau .section-intro { color: rgba(250, 250, 248, 0.65); }
  .reseau .divider { background: var(--c-accent-lt); }

  .reseau__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--sp-lg);
  }

  .reseau__badge {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 9rem;
    height: 9rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    text-align: center;
  }

  .reseau__badge-number {
    font-size: var(--text-4xl);
    font-weight: 200;
    line-height: 1;
    color: #fff;
  }

  .reseau__badge-label {
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.25rem;
  }

  .reseau__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin-block: var(--sp-xl);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .stat {
    background: var(--c-text);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--sp-lg) var(--sp-md);
    text-align: center;
    gap: var(--sp-xs);
  }

  .stat__value {
    font-size: var(--text-4xl);
    font-weight: 200;
    color: #fff;
    letter-spacing: -0.03em;
  }

  .stat__label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
  }

  .reseau__metiers { margin-top: var(--sp-lg); }

  .metiers-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-xs);
  }

  .metiers-list__item {
    padding: 0.4rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 2rem;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.03em;
    transition: border-color 0.2s, color 0.2s;
  }

  .metiers-list__item:hover {
    border-color: var(--c-accent-lt);
    color: #fff;
  }

  @media (max-width: 768px) {
    .reseau__header { flex-direction: column; }
    .reseau__stats { grid-template-columns: 1fr; }
    .reseau__badge { width: 7rem; height: 7rem; }
    .reseau__badge-number { font-size: var(--text-3xl); }
  }
</style>
