---
import { site } from "../site.config";
const { projets } = site;
---

<section class="section" id="projets">
  <div class="container">
    <p class="section-label">Réalisations</p>
    <h2 class="section-title">{projets.title}</h2>
    <div class="divider"></div>
    <p class="section-intro">{projets.intro}</p>

    <ul class="projets-grid">
      {projets.items.map((projet, i) => (
        <li class="projet-card">
          <div class="projet-card__visual" style={`--i: ${i};`}></div>
          <div class="projet-card__body">
            <span class="projet-card__category">{projet.category}</span>
            <h3 class="projet-card__title">{projet.title}</h3>
            <span class="projet-card__year">{projet.year}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .projets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
    gap: 1px;
    background: var(--c-border);
    border: 1px solid var(--c-border);
    margin-top: var(--sp-xl);
  }

  .projet-card {
    background: var(--c-bg);
    display: flex;
    flex-direction: column;
    transition: background 0.2s;
  }

  .projet-card:hover { background: var(--c-surface); }

  .projet-card__visual {
    height: 220px;
    background: color-mix(in srgb, var(--c-accent) calc(30% + var(--i, 0) * 15%), var(--c-surface));
  }

  .projet-card__body {
    padding: var(--sp-md);
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
  }

  .projet-card__category {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-accent);
  }

  .projet-card__title {
    font-size: var(--text-xl);
    font-weight: 400;
  }

  .projet-card__year {
    font-size: var(--text-sm);
    color: var(--c-muted);
    margin-top: auto;
  }
</style>
