---

<footer class:list={["footer", { "footer--fixed": fixed }]}>
  <div class="container footer__inner">

    <!-- Liens nav -->
    <nav class="footer__nav" aria-label="Liens rapides">
      <ul class="footer__links">
        {site.footer.links.map((item) => (
          <li>
            <a href={item.href} class="footer__link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Bas : langue gauche · copyright droite -->
    <div class="footer__bottom">
      <div class="footer__lang" id="lang-switcher" role="group" aria-label="Langue">
        <button class="footer__lang-btn footer__lang-btn--active" data-lang="fr" aria-pressed="true">
          <span class="footer__lang-flag" aria-hidden="true">🇫🇷</span>
          <span>FR</span>
        </button>
        <span class="footer__lang-sep" aria-hidden="true">/</span>
        <button class="footer__lang-btn" data-lang="en" aria-pressed="false">
          <span class="footer__lang-flag" aria-hidden="true">🇬🇧</span>
          <span>EN</span>
        </button>
      </div>
      <span class="footer__copyright">© 2026 Atipics</span>
    </div>

  </div>
</footer>

<script>
  const switcher = document.getElementById("lang-switcher");
  const buttons  = switcher?.querySelectorAll<HTMLButtonElement>(".footer__lang-btn");
  function applyLang(lang: string) {
    document.documentElement.lang = lang;
    buttons?.forEach((btn) => {
      const active = btn.dataset.lang === lang;
      btn.classList.toggle("footer__lang-btn--active", active);
      btn.setAttribute("aria-pressed", String(active));
    });
  }
  buttons?.forEach((btn) => {
    btn.addEventListener("click", () => applyLang(btn.dataset.lang || "fr"));
  });
</script>

<style>
  /* ─── Base ─── */
  .footer {
    padding-block: var(--sp-sm);
    background: var(--c-bg);
  }
  .footer--fixed {
    position: fixed;
    bottom: var(--social-bar-h); left: 0; right: 0;
    z-index: 90;
    height: var(--footer-h);
    padding-block: 0;
  }
  .footer--fixed .footer__inner { height: 100%; }

  /* ─── Layout colonne (toutes pages) ─── */
  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    justify-content: center;
  }

  /* ─── Nav links ─── */
  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-xs) var(--sp-md);
    align-items: center;
    justify-content: center;
  }
  .footer__links li:not(:last-child)::after {
    content: '/';
    margin-left: var(--sp-md);
    color: var(--c-border);
    pointer-events: none;
  }
  .footer__link {
    font-size: var(--text-sm);
    color: var(--c-muted);
    transition: color 0.2s;
  }
  .footer__link:hover { color: var(--c-text); }

  /* ─── Bottom: lang + copyright ─── */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__copyright {
    font-size: var(--text-xs);
    color: var(--c-muted);
    letter-spacing: 0.04em;
  }

  /* ─── Lang ─── */
  .footer__lang {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .footer__lang-sep { font-size: var(--text-xs); color: var(--c-border); }
  .footer__lang-btn {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: 1px solid transparent;
    cursor: pointer;
    font-family: var(--font);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--c-muted);
    padding: 0.2rem 0.4rem;
    transition: color 0.2s, border-color 0.2s;
  }
  .footer__lang-btn:hover      { color: var(--c-text); border-color: var(--c-border); }
  .footer__lang-btn--active    { color: var(--c-text); border-color: var(--c-text); }
  .footer__lang-flag           { font-size: 0.85em; line-height: 1; }

  @media (max-width: 600px) {
    .footer__bottom { flex-wrap: wrap; gap: var(--sp-xs); }
    .footer__socials { gap: var(--sp-xs); }
  }
</style>
