---
import { site } from "../site.config";
---

<footer class="footer">
  <div class="container footer__inner">
    <a href="/" class="footer__logo">{site.name}</a>

    <nav class="footer__nav" aria-label="Liens rapides">
      <ul class="footer__links">
        {site.footer.links.map((item) => (
          <li>
            <a href={item.href} class="footer__link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <p class="footer__legal">{site.footer.legal}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--c-border);
    padding-block: var(--sp-lg);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    align-items: center;
    gap: var(--sp-sm) var(--sp-xl);
  }

  .footer__logo {
    font-size: var(--text-base);
    font-weight: 700;
    letter-spacing: 0.1em;
    grid-row: 1; grid-column: 1;
    transition: color 0.2s;
  }
  .footer__logo:hover { color: var(--c-accent); }

  .footer__nav { grid-row: 1; grid-column: 2; }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-xs) var(--sp-md);
    align-items: center;
  }

  .footer__links li:not(:last-child)::after {
    content: '/';
    margin-left: var(--sp-md);
    color: var(--c-border);
    pointer-events: none;
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--c-muted);
    transition: color 0.2s;
  }
  .footer__link:hover { color: var(--c-text); }

  .footer__legal {
    grid-row: 2; grid-column: 1 / -1;
    font-size: var(--text-xs);
    color: var(--c-muted);
    padding-top: var(--sp-sm);
    border-top: 1px solid var(--c-border);
    margin-top: var(--sp-sm);
  }

  @media (max-width: 600px) {
    .footer__inner { grid-template-columns: 1fr; }
    .footer__nav { grid-row: 2; grid-column: 1; }
    .footer__legal { grid-row: 3; }
  }
</style>
