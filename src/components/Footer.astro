---
import { site } from "../site.config";
interface Props { fixed?: boolean; }
const { fixed = false } = Astro.props;
---

<footer class:list={["footer", { "footer--fixed": fixed }]}>
  <div class="container footer__inner">

    <nav class="footer__nav" aria-label="Liens rapides">
      <ul class="footer__links">
        {site.footer.links.map((item) => (
          <li>
            <a href={item.href} class="footer__link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    {!fixed && <p class="footer__legal">{site.footer.legal}</p>}
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--c-border);
    padding-block: var(--sp-lg);
    background: var(--c-bg);
  }

  .footer--fixed {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 90;
    height: var(--footer-h);
    padding-block: 0;
    border-top: 1px solid var(--c-border);
  }

  .footer--fixed .footer__inner {
    height: 100%;
  }

  .footer__inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--sp-lg);
    flex-wrap: wrap;
  }

  .footer__nav { }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-xs) var(--sp-md);
    align-items: center;
  }

  .footer__links li:not(:last-child)::after {
    content: '/';
    margin-left: var(--sp-md);
    color: var(--c-border);
    pointer-events: none;
  }

  .footer__link {
    font-size: var(--text-base);
    color: var(--c-muted);
    transition: color 0.2s;
  }
  .footer__link:hover { color: var(--c-text); }

  .footer__legal {
    width: 100%;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--c-muted);
    padding-top: var(--sp-sm);
    border-top: 1px solid var(--c-border);
    margin-top: var(--sp-sm);
  }

  @media (max-width: 600px) {
    .footer__inner { gap: var(--sp-md); }
  }
</style>
