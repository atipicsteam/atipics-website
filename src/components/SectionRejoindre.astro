---
import { site } from "../site.config";
const { rejoindre } = site;
---

<section class="section rejoindre" id="rejoindre">
  <div class="container rejoindre__inner">
    <div class="rejoindre__content">
      <p class="section-label" style="color: var(--c-accent-lt);">Intégrez le collectif</p>
      <h2 class="section-title" style="color: #fff;">{rejoindre.title}</h2>
      <div class="divider" style="background: var(--c-accent-lt);"></div>
      <p class="rejoindre__desc">{rejoindre.description}</p>
      <a href="#contact" class="rejoindre__cta">{rejoindre.cta}</a>
    </div>
    <div class="rejoindre__visual" aria-hidden="true">
      <span>A</span>
    </div>
  </div>
</section>

<style>
  .rejoindre {
    background: var(--c-accent);
  }

  .rejoindre__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--sp-xl);
  }

  .rejoindre__desc {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: rgba(250, 250, 248, 0.7);
    max-width: 55ch;
    margin-bottom: var(--sp-lg);
  }

  .rejoindre__cta {
    display: inline-block;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    color: #fff;
    padding: 0.85rem 2.5rem;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.2s, border-color 0.2s;
  }

  .rejoindre__cta:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
  }

  .rejoindre__visual {
    width: 12rem;
    height: 12rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 7rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.08);
    letter-spacing: -0.05em;
    user-select: none;
  }

  @media (max-width: 768px) {
    .rejoindre__inner { grid-template-columns: 1fr; }
    .rejoindre__visual { display: none; }
  }
</style>
