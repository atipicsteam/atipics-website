---
import { site } from "../site.config";
const { journal } = site;
---

<section class="section journal" id="journal">
  <div class="container">
    <p class="section-label">Actualités</p>
    <h2 class="section-title">{journal.title}</h2>
    <div class="divider"></div>
    <p class="section-intro">{journal.intro}</p>

    <ul class="posts">
      {journal.posts.map((post) => (
        <li class="post">
          <span class="post__date">{post.date}</span>
          <div class="post__body">
            <h3 class="post__title">{post.title}</h3>
            <p class="post__excerpt">{post.excerpt}</p>
          </div>
          <span class="post__arrow">&#8594;</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .journal { background: var(--c-surface); }

  .posts {
    margin-top: var(--sp-xl);
    border-top: 1px solid var(--c-border);
  }

  .post {
    display: grid;
    grid-template-columns: 8rem 1fr 2rem;
    align-items: center;
    gap: var(--sp-md);
    padding: var(--sp-lg) 0;
    border-bottom: 1px solid var(--c-border);
    cursor: pointer;
    transition: padding-left 0.25s;
  }

  .post:hover { padding-left: var(--sp-sm); }

  .post__date {
    font-size: var(--text-sm);
    color: var(--c-muted);
    letter-spacing: 0.03em;
  }

  .post__title {
    font-size: var(--text-xl);
    font-weight: 400;
    margin-bottom: var(--sp-xs);
  }

  .post__excerpt {
    font-size: var(--text-sm);
    color: var(--c-muted);
    line-height: 1.6;
    max-width: 60ch;
  }

  .post__arrow {
    font-size: var(--text-xl);
    color: var(--c-accent);
    transition: transform 0.2s;
  }

  .post:hover .post__arrow { transform: translateX(4px); }

  @media (max-width: 600px) {
    .post {
      grid-template-columns: 1fr 2rem;
      grid-template-rows: auto auto;
    }

    .post__date {
      grid-column: 1;
      font-size: var(--text-xs);
    }

    .post__body { grid-column: 1; }
    .post__arrow { grid-row: 1; grid-column: 2; }
  }
</style>
