---
import { site } from "../site.config";
const currentPath = Astro.url.pathname;
---

<header class="header" id="top">
  <div class="container header__inner">
    <a href="/" class="header__logo">{site.name}</a>

    <nav class="nav" aria-label="Navigation principale">
      <ul class="nav__list">
        {site.nav.map((item) => (
          <li class="nav__item">
            <a href={item.href} class:list={["nav__link", { "nav__link--active": currentPath === item.href || currentPath.startsWith(item.href + "/") || currentPath.startsWith(item.href + "#") }]}>
              {item.label}
            </a>
            {item.sub && item.sub.length > 0 && (
              <ul class="nav__sub">
                {item.sub.map((sub) => (
                  <li>
                    <a href={sub.href} class="nav__sub-link">{sub.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  // Mobile toggle
  const toggle = document.querySelector(".menu-toggle") as HTMLButtonElement;
  const nav = document.querySelector(".nav") as HTMLElement;
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    nav.classList.toggle("nav--open", !open);
  });

  // Mobile: tap nav item to expand sub (don't navigate immediately)
  document.querySelectorAll(".nav__item").forEach((item) => {
    const link = item.querySelector(".nav__link") as HTMLAnchorElement;
    const sub = item.querySelector(".nav__sub") as HTMLElement | null;
    if (!sub) return;
    link.addEventListener("click", (e) => {
      if (window.innerWidth <= 900) {
        e.preventDefault();
        item.classList.toggle("nav__item--open");
      }
    });
  });

  // Active state: highlight the nav item matching the current path or visible #section
  const currentPath = window.location.pathname;

  // Map each sub-link href → its parent nav__link element
  const sectionMap = new Map<string, HTMLAnchorElement>();
  document.querySelectorAll(".nav__item").forEach((item) => {
    const navLink = item.querySelector(".nav__link") as HTMLAnchorElement | null;
    if (!navLink) return;
    item.querySelectorAll(".nav__sub-link").forEach((sub) => {
      const href = (sub as HTMLAnchorElement).getAttribute("href") || "";
      const [path, hash] = href.split("#");
      if (path === currentPath && hash) {
        sectionMap.set(hash, navLink);
      }
    });
  });

  // Activate sub-link indicator on scroll via IntersectionObserver
  if (sectionMap.size > 0) {
    const activateSection = (id: string) => {
      // remove all active states first
      document.querySelectorAll(".nav__sub-link--active").forEach((el) =>
        el.classList.remove("nav__sub-link--active")
      );
      document.querySelectorAll(".nav__link").forEach((el) =>
        el.classList.remove("nav__link--active")
      );
      // find the matching sub-link and activate it + its parent nav__link
      document.querySelectorAll(".nav__sub-link").forEach((sub) => {
        const href = (sub as HTMLAnchorElement).getAttribute("href") || "";
        if (href.endsWith(`#${id}`)) {
          sub.classList.add("nav__sub-link--active");
          sectionMap.get(id)?.classList.add("nav__link--active");
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length > 0) activateSection(visible[0].target.id);
      },
      { rootMargin: "-20% 0px -60% 0px", threshold: 0 }
    );

    sectionMap.forEach((_, id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }

  // Shrink on scroll
  const header = document.querySelector(".header") as HTMLElement;
  window.addEventListener("scroll", () => {
    header.classList.toggle("header--scrolled", window.scrollY > 40);
  }, { passive: true });
</script>

<style>
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--c-bg);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .header--scrolled {
    border-color: var(--c-border);
    box-shadow: 0 1px 24px rgba(0,0,0,0.06);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--sp-lg);
    height: var(--nav-h);
  }

  .header__logo {
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: 0.1em;
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .header__logo:hover { color: var(--c-accent); }

  /* ─── Nav ─── */
  .nav { flex: 1; display: flex; justify-content: flex-end; }

  .nav__list {
    display: flex;
    align-items: center;
    gap: var(--sp-lg);
  }

  .nav__item { position: relative; }

  .nav__link {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--c-muted);
    white-space: nowrap;
    padding-block: 0.25rem;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .nav__link:hover {
    color: var(--c-text);
    border-bottom-color: var(--c-text);
  }
  .nav__link--active {
    color: var(--c-text);
    border-bottom-color: var(--c-text);
  }

  /* ─── Dropdown ─── */
  .nav__sub {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 11rem;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    padding: var(--sp-xs) 0;
    padding-top: calc(var(--sp-xs) + 0.75rem);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    /* invisible bridge so hover doesn't break when moving from link to dropdown */
    margin-top: 0;
  }
  /* pseudo-element bridge fills the gap between nav__link and nav__sub */
  .nav__item::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 0.75rem;
  }

  .nav__item:hover .nav__sub {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav__sub-link {
    display: block;
    padding: 0.55rem var(--sp-sm);
    padding-left: calc(var(--sp-sm) + 3px);
    font-size: var(--text-sm);
    color: var(--c-muted);
    border-left: 3px solid transparent;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .nav__sub-link:hover,
  .nav__sub-link--active {
    color: var(--c-text);
    background: var(--c-surface);
    border-left-color: var(--c-accent);
  }

  /* ─── Burger ─── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--sp-xs);
    margin-left: auto;
  }
  .menu-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--c-text);
    transition: transform 0.25s, opacity 0.25s;
  }

  /* ─── Mobile ─── */
  @media (max-width: 900px) {
    .menu-toggle { display: flex; }

    .nav {
      position: fixed;
      top: var(--nav-h); left: 0; right: 0;
      background: var(--c-bg);
      border-bottom: 1px solid var(--c-border);
      padding: var(--sp-sm) var(--sp-md) var(--sp-md);
      transform: translateY(-110%);
      opacity: 0;
      transition: transform 0.3s, opacity 0.3s;
      pointer-events: none;
    }
    .nav--open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .nav__list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }

    .nav__item { width: 100%; }

    .nav__link {
      font-size: var(--text-base);
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--c-border);
      width: 100%;
      justify-content: space-between;
      color: var(--c-text);
    }

    .nav__sub {
      position: static;
      border: none;
      box-shadow: none;
      opacity: 1;
      pointer-events: auto;
      transform: none;
      padding: 0;
      display: none;
      background: var(--c-surface);
    }

    .nav__item--open .nav__sub { display: block; }

    .nav__sub-link {
      padding: 0.6rem var(--sp-md);
      border-bottom: 1px solid var(--c-border);
    }
  }
</style>
